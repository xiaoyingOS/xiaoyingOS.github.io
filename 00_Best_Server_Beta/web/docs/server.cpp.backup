// Web Server Example - File Transfer & WebSocket Support
// 
// Demonstrates:
// - HTTP file upload/download
// - WebSocket for real-time communication (video/voice)
// - Static file serving

#include <best_server/best_server.hpp>
#include <best_server/network/websocket/websocket.hpp>
#include <best_server/io/folder_transfer.hpp>
#include <iostream>
#include <fstream>
#include <sstream>
#include <filesystem>
#include <fcntl.h>
#include <unistd.h>
#include <cerrno>
#include <cstring>
#include <thread>
