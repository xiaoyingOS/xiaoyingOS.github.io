        }

        // 显示图片消息
        function displayImageMessage(message, direction) {
            const container = document.getElementById('messagesContainer');
            
            // 移除空状态
            const emptyState = container.querySelector('.empty-state');
            if (emptyState) {
                emptyState.remove();
            }
            
            // 创建消息元素
            const messageElement = document.createElement('div');
            messageElement.className = `message ${direction}`;
            messageElement.dataset.messageId = message.id;
            
            // 如果有倒计时，添加到消息最前面
            if (message.destroyTime) {
                // 创建倒计时容器
                const countdownContainer = document.createElement('div');
                countdownContainer.className = 'countdown-container';
                
                const countdownRing = document.createElement('div');
                countdownRing.className = 'countdown-ring';
                countdownRing.innerHTML = `
                    <svg>
                        <circle class="background" cx="10" cy="10" r="8"></circle>
                        <circle class="progress" cx="10" cy="10" r="8" 
                                stroke-dasharray="${2 * Math.PI * 8}" 
                                stroke-dashoffset="0"></circle>
                    </svg>
                `;
                
                const timerElement = document.createElement('div');
                timerElement.className = 'message-timer';
                timerElement.textContent = '13s';
                
                // 将计时器文字放到圆环内部
                countdownRing.appendChild(timerElement);
                countdownContainer.appendChild(countdownRing);
                
                // 将倒计时添加到消息元素中
                messageElement.appendChild(countdownContainer);
                
                // 启动倒计时
                startMessageCountdown(message.id, message.destroyTime, timerElement, countdownRing.querySelector('.progress'));
            }
            
            const contentElement = document.createElement('div');
            contentElement.className = 'message-content';
            
            // 如果是闪照消息，添加闪照标识
            if (message.isFlash) {
                const flashBadge = document.createElement('div');
                flashBadge.className = 'flash-badge';
                flashBadge.textContent = '闪照';
                contentElement.appendChild(flashBadge);
            }            
            // 创建图片预览
            const imagePreview = document.createElement('img');
            imagePreview.src = message.content;
            imagePreview.alt = message.fileName;
            imagePreview.style.maxWidth = '200px';
            imagePreview.style.maxHeight = '200px';
            imagePreview.style.borderRadius = '8px';
            imagePreview.style.cursor = 'pointer';
            
            // 如果是闪照图片，设置为模糊状态
            if (message.isFlash && message.type === 'image') {
                imagePreview.style.filter = 'blur(8px) brightness(0.5)';
            }
            imagePreview.onclick = () => {
                // 点击图片直接全屏查看
                console.log('图片被点击');
                
                // 创建全屏查看容器
                const fullscreenContainer = document.createElement('div');
                fullscreenContainer.style.position = 'fixed';
                fullscreenContainer.style.top = '0';
                fullscreenContainer.style.left = '0';
                fullscreenContainer.style.width = '100vw';
                fullscreenContainer.style.height = '100vh';
                fullscreenContainer.style.background = 'rgba(0, 0, 0, 0.9)';
                fullscreenContainer.style.display = 'flex';
                fullscreenContainer.style.justifyContent = 'center';
                fullscreenContainer.style.alignItems = 'center';
                fullscreenContainer.style.zIndex = '10000';
                fullscreenContainer.style.touchAction = 'none'; // 防止触摸时页面滚动
                
                // 创建图片容器
                const imageContainer = document.createElement('div');
                imageContainer.style.position = 'relative';
                imageContainer.style.width = '100%';
                imageContainer.style.height = '100%';
                imageContainer.style.display = 'flex';
                imageContainer.style.justifyContent = 'center';
                imageContainer.style.alignItems = 'center';
                imageContainer.style.overflow = 'hidden';
                
                // 拖拽和缩放状态
                let isDragging = false;
                let startX, startY;
                let translateX = 0;
                let translateY = 0;
                let scale = 1;
                

                const updateTransform = () => {
                    displayImage.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
                };
                
                // 拖拽功能
                const handleDragStart = (e) => {
                    e.stopPropagation(); // 阻止事件冒泡
                    if (e.touches.length === 1 && scale > 1) {
                        isDragging = true;
                        startX = e.touches[0].clientX - translateX;
                        startY = e.touches[0].clientY - translateY;
                        imageContainer.style.cursor = 'grabbing';
                        displayImage.style.transition = 'none'; // 拖动时禁用过渡动画
                    }
                };
                
                const handleDragMove = (e) => {
                    e.stopPropagation(); // 阻止事件冒泡
                    if (isDragging && e.touches.length === 1 && scale > 1) {
                        e.preventDefault();
                        const currentX = e.touches[0].clientX;
                        const currentY = e.touches[0].clientY;
                        
                        translateX = currentX - startX;
                        translateY = currentY - startY;
                        
                        updateTransform();
                    }
                };
                
                const handleDragEnd = (e) => {
                    e.stopPropagation(); // 阻止事件冒泡
                    isDragging = false;
                    imageContainer.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
                    displayImage.style.transition = 'transform 0.3s ease'; // 恢复过渡动画
                };
                
                // 创建图片元素
                const displayImage = document.createElement('img');
                displayImage.src = message.content;
                displayImage.style.maxWidth = '100%';
                displayImage.style.maxHeight = '100%';
                displayImage.style.objectFit = 'contain';
                displayImage.style.borderRadius = '8px';
                displayImage.style.boxShadow = '0 0 20px rgba(0, 0, 0, 0.5)';
                displayImage.style.transition = 'transform 0.3s ease, filter 0.3s ease';
                displayImage.style.touchAction = 'none'; // 防止触摸时页面滚动
                
                // 闪照功能变量
                let isFlashImage = message.isFlash && message.type === 'image';
                let isViewing = false;
                let viewTimer = null;
                let countdownTimer = null;
                let remainingTime = 5; // 5秒倒计时
                
                // 如果是闪照图片，初始设置为模糊状态
                if (isFlashImage) {
                    displayImage.style.filter = 'blur(15px) brightness(0.3)';
                    
                    // 创建查看提示
                    const viewHint = document.createElement('div');
                    viewHint.textContent = '长按查看闪照';
                    viewHint.style.position = 'absolute';
                    viewHint.style.top = '50%';
                    viewHint.style.left = '50%';
                    viewHint.style.transform = 'translate(-50%, -50%)';
                    viewHint.style.color = 'white';
                    viewHint.style.background = 'rgba(0, 0, 0, 0.7)';
                    viewHint.style.padding = '10px 20px';
                    viewHint.style.borderRadius = '20px';
                    viewHint.style.fontSize = '16px';
                    viewHint.style.zIndex = '10002';
                    viewHint.style.pointerEvents = 'none';
                    viewHint.style.userSelect = 'none';
                    imageContainer.appendChild(viewHint);
                    
                    // 创建倒计时显示
                    const countdownDisplay = document.createElement('div');
                    countdownDisplay.style.position = 'absolute';
                    countdownDisplay.style.top = '20px';
                    countdownDisplay.style.left = '50%';
                    countdownDisplay.style.transform = 'translateX(-50%)';
                    countdownDisplay.style.color = 'white';
                    countdownDisplay.style.background = 'rgba(255, 0, 0, 0.8)';
                    countdownDisplay.style.padding = '8px 16px';
                    countdownDisplay.style.borderRadius = '15px';
                    countdownDisplay.style.fontSize = '18px';
                    countdownDisplay.style.fontWeight = 'bold';
                    countdownDisplay.style.zIndex = '10003';
                    countdownDisplay.style.display = 'none';
                    countdownDisplay.style.pointerEvents = 'none';
                    countdownDisplay.style.userSelect = 'none';
                    imageContainer.appendChild(countdownDisplay);
                    
                    // 长按开始查看
                    const startViewing = () => {
                        if (!isViewing && isFlashImage) {
                            isViewing = true;
                            displayImage.style.filter = 'none';
                            viewHint.style.display = 'none';
                            countdownDisplay.style.display = 'block';
                            
                            // 闪照长按查看始终是5秒
                            let viewRemainingTime = 5;
                            countdownDisplay.textContent = `${viewRemainingTime}秒`;
                            
                            // 开始倒计时
                            countdownTimer = setInterval(() => {
                                viewRemainingTime--;
                                countdownDisplay.textContent = `${viewRemainingTime}秒`;
                                
                                if (viewRemainingTime <= 0) {
                                    clearInterval(countdownTimer);
                                    // 销毁闪照
                                    destroyMessage(message.id);
                                    showNotification('闪照已销毁', 'info');
                                    // 关闭全屏查看
                                    document.body.removeChild(fullscreenContainer);
                                }
                            }, 1000);
                        }
                    };
                    
                    // 停止查看
                    const stopViewing = () => {
                        if (isViewing && isFlashImage) {
                            isViewing = false;
                            
                            // 清除倒计时
                            if (countdownTimer) {
                                clearInterval(countdownTimer);
                                countdownTimer = null;
                            }
                            
                            // 无论观看时间长短，都直接销毁闪照
                            destroyMessage(message.id);
                            showNotification('闪照已销毁', 'info');
                        }
                    };
                    
                    // 添加长按事件
                    let pressTimer = null;
                    
                    const handlePressStart = (e) => {
                        e.preventDefault();
                        pressTimer = setTimeout(startViewing, 500); // 长按500ms后开始查看
                    };
                    
                    const handlePressEnd = () => {
                        if (pressTimer) {
                            clearTimeout(pressTimer);
                            pressTimer = null;
                        }
                        stopViewing();
                    };
                    
                    // 鼠标事件
                    displayImage.addEventListener('mousedown', handlePressStart);
                    displayImage.addEventListener('mouseup', handlePressEnd);
                    displayImage.addEventListener('mouseleave', handlePressEnd);
                    
                    // 触摸事件
                    displayImage.addEventListener('touchstart', handlePressStart, { passive: false });
                    displayImage.addEventListener('touchend', handlePressEnd);
                    displayImage.addEventListener('touchcancel', handlePressEnd);
                }
                
                // 手指捏合缩放功能
                const handleZoomStart = (e) => {
                    e.stopPropagation(); // 阻止事件冒泡
                    if (e.touches.length === 2) {
                        e.preventDefault();
                        
                        // 计算两指中心点
                        const centerX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
                        const centerY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
                        
                        const initialDistance = Math.hypot(
                            e.touches[0].clientX - e.touches[1].clientX,
                            e.touches[0].clientY - e.touches[1].clientY
                        );
                        
                        // 存储初始距离、缩放比例和中心点
                        displayImage.dataset.initialDistance = initialDistance;
                        displayImage.dataset.initialScale = scale;
                        displayImage.dataset.centerX = centerX;
                        displayImage.dataset.centerY = centerY;
                        displayImage.dataset.initialTranslateX = translateX;
                        displayImage.dataset.initialTranslateY = translateY;
                        
                        displayImage.style.transition = 'none'; // 缩放时禁用过渡动画
                    }
                };
                
                const handleZoomMove = (e) => {
                    e.stopPropagation(); // 阻止事件冒泡
                    if (e.touches.length === 2) {
                        e.preventDefault();
                        const initialDistance = parseFloat(displayImage.dataset.initialDistance);
                        const initialScale = parseFloat(displayImage.dataset.initialScale);
                        const centerX = parseFloat(displayImage.dataset.centerX);
                        const centerY = parseFloat(displayImage.dataset.centerY);
                        const initialTranslateX = parseFloat(displayImage.dataset.initialTranslateX);
                        const initialTranslateY = parseFloat(displayImage.dataset.initialTranslateY);
                        
                        if (initialDistance > 0) {
                            const currentDistance = Math.hypot(
                                e.touches[0].clientX - e.touches[1].clientX,
                                e.touches[0].clientY - e.touches[1].clientY
                            );
                            
                            const scaleFactor = currentDistance / initialDistance;
                            const newScale = initialScale * scaleFactor;
                            
                            // 限制缩放范围
                            if (newScale >= 0.5 && newScale <= 3) {
                                // 计算新的中心点
                                const newCenterX = (e.touches[0].clientX + e.touches[1].clientX) / 2;
                                const newCenterY = (e.touches[0].clientY + e.touches[1].clientY) / 2;
                                
                                // 调整位置，使缩放中心保持在两指中心
                                const scaleDiff = newScale - initialScale;
                                // 避免除零错误
                                const safeScale = initialScale > 0 ? initialScale : 1;
                                translateX = initialTranslateX - (newCenterX - centerX) * scaleDiff / safeScale;
                                translateY = initialTranslateY - (newCenterY - centerY) * scaleDiff / safeScale;
                                scale = newScale;
                                
                                updateTransform();
                            }
                        }
                    }
                };
                
                const handleZoomEnd = (e) => {
                    e.stopPropagation(); // 阻止事件冒泡
                    displayImage.style.transition = 'transform 0.3s ease'; // 恢复过渡动画
                };
                
                // 双击重置缩放
                const handleDoubleClick = (e) => {
                    e.stopPropagation(); // 阻止事件冒泡
                    e.preventDefault(); // 阻止默认行为
                    scale = 1;
                    translateX = 0;
                    translateY = 0;
                    updateTransform();
                };
                
                // 添加事件监听器
                displayImage.addEventListener('touchstart', (e) => {
                    if (e.touches.length === 1) {
                        handleDragStart(e);
                    } else if (e.touches.length === 2) {
                        handleZoomStart(e);
                    }
                });
                displayImage.addEventListener('touchmove', (e) => {
                    if (e.touches.length === 1) {
                        handleDragMove(e);
                    } else if (e.touches.length === 2) {
                        handleZoomMove(e);
                    }
                });
                displayImage.addEventListener('touchend', (e) => {
                    if (e.touches.length === 0) {
                        handleDragEnd();
                        handleZoomEnd();
                    }
                });
                displayImage.addEventListener('dblclick', handleDoubleClick);
                
                // 为容器也添加事件监听器
                imageContainer.addEventListener('touchstart', (e) => {
                    if (e.touches.length === 1) {
                        handleDragStart(e);
                    } else if (e.touches.length === 2) {
                        handleZoomStart(e);
                    }
                });
                imageContainer.addEventListener('touchmove', (e) => {
                    if (e.touches.length === 1) {
                        handleDragMove(e);
                    } else if (e.touches.length === 2) {
                        handleZoomMove(e);
                    }
                });
                imageContainer.addEventListener('touchend', (e) => {
                    if (e.touches.length === 0) {
                        handleDragEnd();
                        handleZoomEnd();
                    }
                });
                
                // 添加关闭提示
                const closeHint = document.createElement('div');
                closeHint.textContent = '捏合缩放 | 点击外部关闭';
                closeHint.style.position = 'absolute';
                closeHint.style.top = '20px';
                closeHint.style.right = '20px';
                closeHint.style.color = 'white';
                closeHint.style.background = 'rgba(0, 0, 0, 0.7)';
                closeHint.style.padding = '8px 15px';
                closeHint.style.borderRadius = '20px';
                closeHint.style.fontSize = '14px';
                closeHint.style.zIndex = '10001';
                
                // 添加图片名称
                const imageName = document.createElement('div');
                imageName.textContent = message.fileName;
                imageName.style.position = 'absolute';
                imageName.style.bottom = '20px';
                imageName.style.left = '20px';
                imageName.style.color = 'white';
                imageName.style.background = 'rgba(0, 0, 0, 0.7)';
                imageName.style.padding = '8px 15px';
                imageName.style.borderRadius = '20px';
                imageName.style.fontSize = '14px';
                imageName.style.maxWidth = '300px';
                imageName.style.wordWrap = 'break-word';
                imageName.style.overflowWrap = 'break-word';
                imageName.style.zIndex = '10001';
                
                // 添加元素到容器
                imageContainer.appendChild(displayImage);
                fullscreenContainer.appendChild(imageContainer);
                fullscreenContainer.appendChild(closeHint);
                fullscreenContainer.appendChild(imageName);
                
                // 防止全屏容器的触摸事件穿透
                fullscreenContainer.addEventListener('touchstart', (e) => {
                    if (e.target === fullscreenContainer) {
                        e.stopPropagation();
                        e.preventDefault();
                    }
                });
                
                fullscreenContainer.addEventListener('touchmove', (e) => {
                    if (e.target === fullscreenContainer) {
                        e.stopPropagation();
                        e.preventDefault();
                    }
                });
                
                // 点击任意区域关闭
                fullscreenContainer.onclick = (e) => {
                    document.body.removeChild(fullscreenContainer);
                };
                
                // 添加到页面
                document.body.appendChild(fullscreenContainer);
                
                // ESC键关闭
                const handleKeyPress = (e) => {
                    if (e.key === 'Escape') {
                        document.body.removeChild(fullscreenContainer);
                        document.removeEventListener('keydown', handleKeyPress);
                    }
                };
                document.addEventListener('keydown', handleKeyPress);
            };
            
            const infoElement = document.createElement('div');
            infoElement.className = 'file-info';
            
            // 处理文件名，手动插入换行符
            let fileName = message.fileName;
            const maxCharsPerLine = 30; // 每行最大字符数
            let formattedFileName = '';
            
            for (let i = 0; i < fileName.length; i++) {
                formattedFileName += fileName[i];
                if ((i + 1) % maxCharsPerLine === 0 && i < fileName.length - 1) {
                    formattedFileName += '\n';
                }
            }
            
            infoElement.innerHTML = `
                <div class="file-name" style="white-space: pre-line;">🖼️ ${formattedFileName}</div>
                <div class="file-size">${formatFileSize(message.fileSize)}</div>
                <div class="file-resolution">分辨率: 加载中...</div>
            `;
            
            // 创建图片元素获取分辨率
            const img = new Image();
            img.onload = function() {
                const resolutionElement = infoElement.querySelector('.file-resolution');
                if (resolutionElement) {
                    resolutionElement.textContent = `分辨率: ${this.width}×${this.height}`;
                }
            };
            img.src = message.content;
            
            const timeElement = document.createElement('div');
            timeElement.className = 'message-time';
            timeElement.textContent = formatTime(message.timestamp);
            
            contentElement.appendChild(imagePreview);
            contentElement.appendChild(infoElement);
            contentElement.appendChild(timeElement);
            messageElement.appendChild(contentElement);
            
            // 添加长按事件
            addLongPressEvent(messageElement, message);
            
            container.appendChild(messageElement);
            
            // 图片加载完成后滚动到底部
            imagePreview.onload = () => {
                setTimeout(() => {
                    container.scrollTop = container.scrollHeight;
                }, 100);
            };
        }

        // 显示视频消息
        function displayVideoMessage(message, direction) {
            const container = document.getElementById('messagesContainer');
            
            // 移除空状态
            const emptyState = container.querySelector('.empty-state');
            if (emptyState) {
                emptyState.remove();
            }
            
            // 创建消息元素
            const messageElement = document.createElement('div');
            messageElement.className = `message ${direction}`;
            messageElement.dataset.messageId = message.id;
            
            // 如果有倒计时，添加到消息最前面
            if (message.destroyTime) {
                // 创建倒计时容器
                const countdownContainer = document.createElement('div');
                countdownContainer.className = 'countdown-container';
                
                const countdownRing = document.createElement('div');
                countdownRing.className = 'countdown-ring';
                countdownRing.innerHTML = `
                    <svg>
                        <circle class="background" cx="10" cy="10" r="8"></circle>
                        <circle class="progress" cx="10" cy="10" r="8" 
                                stroke-dasharray="${2 * Math.PI * 8}" 
                                stroke-dashoffset="0"></circle>
                    </svg>
                `;
                
                const timerElement = document.createElement('div');
                timerElement.className = 'message-timer';
                timerElement.textContent = '13s';
                
                // 将计时器文字放到圆环内部
                countdownRing.appendChild(timerElement);
                countdownContainer.appendChild(countdownRing);
                
                // 将倒计时添加到消息元素中
                messageElement.appendChild(countdownContainer);
                
                // 启动倒计时
                startMessageCountdown(message.id, message.destroyTime, timerElement, countdownRing.querySelector('.progress'));
            }
            
            const contentElement = document.createElement('div');
            contentElement.className = 'message-content';
            
            // 创建视频预览
            const videoPreview = document.createElement('video');
            videoPreview.src = message.content;
            videoPreview.controls = true;
            videoPreview.preload = 'metadata';
            // 确保控件完整显示，包括声音和全屏按钮
            videoPreview.controlsList = ''; // 不隐藏任何控件
            // 初始设置，加载元数据后会根据实际比例调整
            videoPreview.style.cssText = 'width: 200px; height: auto; max-width: 250px; max-height: 300px; object-fit: contain; border-radius: 8px; display: block; margin: 0 auto;';
            
            // 添加视频加载事件处理
            videoPreview.addEventListener('loadedmetadata', function() {
                // 获取视频实际宽高
                const videoWidth = videoPreview.videoWidth || 320;
                const videoHeight = videoPreview.videoHeight || 240;
                const aspectRatio = videoWidth / videoHeight;
                
                // 根据视频比例调整显示尺寸
                let displayWidth, displayHeight;
                const maxWidth = 250;
                const maxHeight = 300;
                
                if (aspectRatio > 1) {
                    // 横屏视频，以宽度为基准
                    displayWidth = Math.min(videoWidth, maxWidth);
                    displayHeight = displayWidth / aspectRatio;
                    
                    // 应用计算后的尺寸
                    videoPreview.style.width = displayWidth + 'px';
                    videoPreview.style.height = displayHeight + 'px';
                    
                    // 标记为已处理
                    videoPreview.setAttribute('data-processed', 'true');
                    
                    // 将横屏视频添加到内容元素
                    contentElement.appendChild(videoPreview);
                    contentElement.appendChild(infoElement);
                } else {
                    // 竖屏视频，以高度为基准
                    displayHeight = Math.min(videoHeight, maxHeight);
                    displayWidth = displayHeight * aspectRatio;
                    
                    // 应用计算后的尺寸
                    videoPreview.style.width = displayWidth + 'px';
                    videoPreview.style.height = displayHeight + 'px';
                    
                    // 创建静音/取消静音按钮
                    const muteBtn = document.createElement('button');
                    muteBtn.innerHTML = '🔊';
                    muteBtn.style.cssText = `
                        background: rgba(0, 0, 0, 0.7);
                        color: white;
                        border: none;
                        border-radius: 50%;
                        width: 36px;
                        height: 36px;
                        cursor: pointer;
                        font-size: 16px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        pointer-events: auto;
                    `;
                    muteBtn.title = '静音/取消静音';
                    
                    // 创建全屏按钮
                    const fullscreenBtn = document.createElement('button');
                    fullscreenBtn.innerHTML = '⛶';
                    fullscreenBtn.style.cssText = `
                        background: rgba(0, 0, 0, 0.7);
                        color: white;
                        border: none;
                        border-radius: 50%;
                        width: 36px;
                        height: 36px;
                        cursor: pointer;
                        font-size: 16px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        pointer-events: auto;
                    `;
                    fullscreenBtn.title = '全屏';
                    
                    // 静音按钮事件
                    muteBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        videoPreview.muted = !videoPreview.muted;
                        muteBtn.innerHTML = videoPreview.muted ? '🔇' : '🔊';
                    });
                    
                    // 全屏按钮事件
                    fullscreenBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        if (videoPreview.requestFullscreen) {
                            videoPreview.requestFullscreen();
                        } else if (videoPreview.webkitRequestFullscreen) { /* Safari */
                            videoPreview.webkitRequestFullscreen();
                        } else if (videoPreview.msRequestFullscreen) { /* IE11 */
                            videoPreview.msRequestFullscreen();
                        }
                    });
                    
                    // 为竖屏视频创建覆盖层
                    const overlay = document.createElement('div');
                    overlay.style.cssText = `
                        position: absolute;
                        top: 0;
                        left: 0;
                        width: ${displayWidth}px;
                        height: ${displayHeight}px;
                        display: flex;
                        justify-content: center;
                        align-items: flex-end;
                        gap: 15px;
                        padding-bottom: 15px;
                        background: linear-gradient(to top, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0));
                        border-radius: 8px;
                        pointer-events: none;
                        box-sizing: border-box;
                    `;
                    
                    // 将按钮添加到覆盖层
                    overlay.appendChild(muteBtn);
                    overlay.appendChild(fullscreenBtn);
                    
                    // 将视频元素包装在一个容器中
                    const videoWrapper = document.createElement('div');
                    videoWrapper.style.cssText = `
                        position: relative;
                        display: inline-block;
                        width: ${displayWidth}px;
                        height: ${displayHeight}px;
                    `;
                    
                    // 将视频元素移到包装器中
                    if (videoPreview.parentNode) {
                        videoPreview.parentNode.removeChild(videoPreview);
                    }
                    videoWrapper.appendChild(videoPreview);
                    videoWrapper.appendChild(overlay);
                    
                    // 将包装器添加到内容元素
                    contentElement.appendChild(videoWrapper);
                    
                    // 然后添加文件信息，确保在视频下方
                    contentElement.appendChild(infoElement);
                }
                
                // 创建canvas来捕获第一帧作为封面
                try {
                    const canvas = document.createElement('canvas');
                    canvas.width = videoWidth;
                    canvas.height = videoHeight;
                    const ctx = canvas.getContext('2d');
                    
                    // 绘制第一帧
                    ctx.drawImage(videoPreview, 0, 0, canvas.width, canvas.height);
                    
                    // 将canvas转换为图片URL并设置为poster
                    videoPreview.poster = canvas.toDataURL('image/jpeg', 0.8);
                } catch (e) {
                    console.error('生成视频封面失败:', e);
                }
                
                // 滚动到底部
                setTimeout(() => {
                    container.scrollTop = container.scrollHeight;
                }, 100);
            });
            
            // 处理视频加载错误
            videoPreview.addEventListener('error', function() {
                console.error('视频加载失败');
                // 显示错误信息
                videoPreview.style.display = 'none';
                const errorMsg = document.createElement('div');
                errorMsg.textContent = '视频加载失败';
                errorMsg.style.cssText = 'color: red; text-align: center; padding: 10px;';
                contentElement.appendChild(errorMsg);
            });
            
            // 添加视频播放事件，实现闪照功能
            videoPreview.addEventListener('play', function() {
                // 如果是闪照视频，播放后立即销毁
                if (message.isFlash && message.type === 'video') {
                    // 立即销毁消息
                    destroyMessage(message.id);
                    showNotification('闪照视频已播放，消息已销毁', 'info');
                }
            });
            
            // 为闪照视频添加长按查看机制
            if (message.isFlash && message.type === 'video') {
                // 创建视频容器包装器，用于添加长按事件
                const videoWrapper = document.createElement('div');
                videoWrapper.style.position = 'relative';
                videoWrapper.style.display = 'inline-block';
                videoWrapper.style.maxWidth = '250px';
                videoWrapper.style.maxHeight = '300px';
                
                // 将视频移到包装器中
                if (videoPreview.parentNode) {
                    videoPreview.parentNode.removeChild(videoPreview);
                }
                videoWrapper.appendChild(videoPreview);
                
                // 闪照功能变量
                let isViewing = false;
                let viewTimer = null;
                let countdownTimer = null;
                let remainingTime = 5; // 5秒倒计时
                
                // 初始设置为模糊状态
                videoPreview.style.filter = 'blur(15px) brightness(0.3)';
                videoPreview.style.pointerEvents = 'none'; // 禁止直接点击
                
                // 创建查看提示
                const viewHint = document.createElement('div');
                viewHint.textContent = '长按查看闪照';
                viewHint.style.position = 'absolute';
                viewHint.style.top = '50%';
                viewHint.style.left = '50%';
                viewHint.style.transform = 'translate(-50%, -50%)';
                viewHint.style.color = 'white';
                viewHint.style.background = 'rgba(0, 0, 0, 0.7)';
                viewHint.style.padding = '10px 20px';
                viewHint.style.borderRadius = '20px';
                viewHint.style.fontSize = '16px';
                viewHint.style.zIndex = '10002';
                viewHint.style.pointerEvents = 'none';
                viewHint.style.userSelect = 'none';
                videoWrapper.appendChild(viewHint);
                
                // 创建倒计时显示
                const countdownDisplay = document.createElement('div');
                countdownDisplay.style.position = 'absolute';
                countdownDisplay.style.top = '10px';
                countdownDisplay.style.left = '50%';
                countdownDisplay.style.transform = 'translateX(-50%)';
                countdownDisplay.style.color = 'white';
                countdownDisplay.style.background = 'rgba(255, 0, 0, 0.8)';
                countdownDisplay.style.padding = '8px 16px';
                countdownDisplay.style.borderRadius = '15px';
                countdownDisplay.style.fontSize = '18px';
                countdownDisplay.style.fontWeight = 'bold';
                countdownDisplay.style.zIndex = '10003';
                countdownDisplay.style.display = 'none';
                countdownDisplay.style.pointerEvents = 'none';
                countdownDisplay.style.userSelect = 'none';
                videoWrapper.appendChild(countdownDisplay);
                
                // 长按开始查看
                const startViewing = () => {
                    if (!isViewing) {
                        isViewing = true;
                        videoPreview.style.filter = 'none';
                        videoPreview.style.pointerEvents = 'auto'; // 允许交互
                        viewHint.style.display = 'none';
                        countdownDisplay.style.display = 'block';
                        
                        // 闪照长按查看始终是5秒
                        let viewRemainingTime = 5;
                        countdownDisplay.textContent = `${viewRemainingTime}秒`;
                        
                        // 自动播放视频
                        videoPreview.play();
                        
                        // 开始倒计时
                        countdownTimer = setInterval(() => {
                            viewRemainingTime--;
                            countdownDisplay.textContent = `${viewRemainingTime}秒`;
                            
                            if (viewRemainingTime <= 0) {
                                clearInterval(countdownTimer);
                                // 销毁闪照
                                destroyMessage(message.id);
                                showNotification('闪照已销毁', 'info');
                            }
                        }, 1000);
                    }
                };
                
                // 停止查看
                const stopViewing = () => {
                    if (isViewing) {
                        isViewing = false;
                        
                        // 清除倒计时
                        if (countdownTimer) {
                            clearInterval(countdownTimer);
                            countdownTimer = null;
                        }
                        
                        // 无论观看时间长短，都直接销毁闪照
                        destroyMessage(message.id);
                        showNotification('闪照已销毁', 'info');
                    }
                };
                
                // 添加长按事件
                let pressTimer = null;
                
                const handlePressStart = (e) => {
                    e.preventDefault();
                    pressTimer = setTimeout(startViewing, 500); // 长按500ms后开始查看
                };
                
                const handlePressEnd = () => {
                    if (pressTimer) {
                        clearTimeout(pressTimer);
                        pressTimer = null;
                    }
                    stopViewing();
                };
                
                // 鼠标事件
                videoWrapper.addEventListener('mousedown', handlePressStart);
                videoWrapper.addEventListener('mouseup', handlePressEnd);
                videoWrapper.addEventListener('mouseleave', handlePressEnd);
                
                // 触摸事件
                videoWrapper.addEventListener('touchstart', handlePressStart, { passive: false });
                videoWrapper.addEventListener('touchend', handlePressEnd);
                videoWrapper.addEventListener('touchcancel', handlePressEnd);
                
                // 将包装器添加到内容元素
                contentElement.appendChild(videoWrapper);
            } else {
                // 非闪照视频，正常添加
                contentElement.appendChild(videoPreview);
            }
            
            // 创建视频信息
            const infoElement = document.createElement('div');
            infoElement.className = 'file-info';
            
            // 格式化视频时长
            let durationText = '';
            if (message.duration && !isNaN(message.duration)) {
                const minutes = Math.floor(message.duration / 60);
                const seconds = Math.floor(message.duration % 60);
                durationText = `时长: ${minutes}:${seconds.toString().padStart(2, '0')}`;
            }
            
            // 添加视频分辨率和帧率信息
            let resolutionText = '';
            let frameRateText = '';
            
            videoPreview.addEventListener('loadedmetadata', function() {
                const width = videoPreview.videoWidth;
                const height = videoPreview.videoHeight;
                resolutionText = `分辨率: ${width}×${height}`;
                
                // 尝试获取帧率（注意：不是所有视频都包含帧率信息）
                // 由于浏览器API限制，我们无法直接获取帧率，这里只显示分辨率
                // 更新显示
                const durationElement = infoElement.querySelector('.file-duration');
                if (durationElement) {
                    durationElement.textContent = durationText + ' | ' + resolutionText;
                }
            });
            
            // 处理文件名，手动插入换行符
            let fileName = message.fileName;
            const maxCharsPerLine = 30; // 每行最大字符数
            let formattedFileName = '';
            
            for (let i = 0; i < fileName.length; i++) {
                formattedFileName += fileName[i];
                if ((i + 1) % maxCharsPerLine === 0 && i < fileName.length - 1) {
                    formattedFileName += '\n';
                }
            }
            
            infoElement.innerHTML = `
                <div class="file-name" style="white-space: pre-line;">🎬 ${formattedFileName}</div>
                <div class="file-size">${formatFileSize(message.fileSize)}</div>
                ${durationText ? `<div class="file-duration">${durationText}</div>` : ''}
            `;
            
            const timeElement = document.createElement('div');
            timeElement.className = 'message-time';
            timeElement.textContent = formatTime(message.timestamp);
            
timeElement.className = 'message-time';
            timeElement.textContent = formatTime(message.timestamp);
            
// 添加一个标记，表示是否是竖屏视频
            let isPortraitVideo = false;
            
            // 监听视频元数据加载完成
            videoPreview.addEventListener('loadedmetadata', function() {
                const aspectRatio = videoPreview.videoWidth / videoPreview.videoHeight;
                isPortraitVideo = aspectRatio <= 1;
                
                // 如果是竖屏视频，添加文件信息到视频容器下方
                if (isPortraitVideo && videoPreview.hasAttribute('data-processed')) {
                    const videoWrapper = contentElement.querySelector('.video-wrapper');
                    if (videoWrapper) {
                        videoWrapper.appendChild(infoElement);
                    }
                }
            });
            
            // 对于横屏视频，按原来的顺序添加
            if (!videoPreview.hasAttribute('data-processed')) {
                contentElement.appendChild(videoPreview);
                contentElement.appendChild(infoElement);
            }
            
            contentElement.appendChild(timeElement);
            messageElement.appendChild(contentElement);
            
            // 添加长按事件
            addLongPressEvent(messageElement, message);
            
            container.appendChild(messageElement);
        }

        // 消息倒计时函数
        function startMessageCountdown(messageId, destroyTime, timerElement, progressCircle) {
            // 查找消息
            const message = appState.messageHistory.find(msg => msg.id === messageId);
            
            // 如果是闪照消息且没有设置销毁时间，不启动自动倒计时，只有观看后才销毁
            if (message && message.isFlash && !destroyTime) {
                // 隐藏倒计时，但保留元素以便观看时使用
                if (timerElement) {
                    timerElement.style.display = 'none';
                }
                if (progressCircle) {
                    progressCircle.style.display = 'none';
                }
                return;
            }
            
            // 非闪照消息或设置了销毁时间的闪照消息正常倒计时
            const startTime = Date.now();
            const duration = 13000; // 13秒
            const circumference = 2 * Math.PI * 8; // 圆环周长
            
            const updateTimer = () => {
                const elapsed = Date.now() - startTime;
                const remaining = Math.max(0, duration - elapsed);
                const seconds = Math.ceil(remaining / 1000);
                
                // 更新倒计时文本
                timerElement.textContent = `${seconds}s`;
                
                // 更新进度环
                const offset = circumference - (elapsed / duration) * circumference;
                progressCircle.style.strokeDashoffset = offset;
                
                if (remaining > 0) {
                    requestAnimationFrame(updateTimer);
                } else {
                    // 销毁消息
                    destroyMessage(messageId);
                }
            };
            
            requestAnimationFrame(updateTimer);
        }

        // 销毁消息函数
        function destroyMessage(messageId) {
            const messageElement = document.querySelector(`[data-message-id="${messageId}"]`);
            if (messageElement) {
                // 检查是否有全屏查看的图片/视频，如果有则关闭
                const fullscreenContainers = document.querySelectorAll('[style*="position: fixed"][style*="z-index: 10000"]');
                fullscreenContainers.forEach(container => {
                    // 检查是否是当前消息的全屏查看
                    if (container.querySelector('img, video')) {
                        document.body.removeChild(container);
                    }
                });
                
                // 对于闪照图片/视频，立即替换为销毁提示
                const message = appState.messageHistory.find(msg => msg.id === messageId);
                if (message && message.isFlash && (message.type === 'image' || message.type === 'video')) {
                    const contentElement = messageElement.querySelector('.message-content');
                    if (contentElement) {
                        // 清空内容元素
                        contentElement.innerHTML = '';
                        
                        // 创建销毁提示
                        const destroyNotice = document.createElement('div');
                        destroyNotice.style.cssText = 'padding: 20px; text-align: center; color: var(--text-secondary);';
                        destroyNotice.innerHTML = `
                            <div style="font-size: 24px; margin-bottom: 10px;">🔥</div>
                            <div style="font-size: 16px; font-weight: bold;">闪照已销毁</div>
                            <div style="font-size: 12px; margin-top: 5px;">内容已永久消失</div>
                        `;
                        
                        contentElement.appendChild(destroyNotice);
                    }
                } else {
                    // 非闪照消息，使用销毁动画
                    messageElement.classList.add('message-destroying');
                }
                
                // 动画结束后移除消息
                setTimeout(() => {
                    messageElement.remove();
                    
                    // 从消息历史中移除
                    appState.messageHistory = appState.messageHistory.filter(msg => msg.id !== messageId);
                    
                    // 检查是否需要显示空状态
                    const container = document.getElementById('messagesContainer');
                    if (container.children.length === 0) {
                        showEmptyState();
                    }
                }, 500);
            }
        }

        // 添加长按事件
        function addLongPressEvent(element, message) {
            let pressTimer = null;
            let isLongPress = false;
            let touchMoved = false;
            let touchStartX = 0;
            let touchStartY = 0;
            
            const startPress = (e) => {
                isLongPress = false;
                touchMoved = false;
                
                // 记录触摸起始位置
                if (e.type === 'touchstart') {
                    touchStartX = e.touches[0].clientX;
                    touchStartY = e.touches[0].clientY;
                }
                
                pressTimer = setTimeout(() => {
                    if (!touchMoved) {
                        isLongPress = true;
                        showMessageMenu(e, message);
                    }
                }, 500); // 500ms长按时间
            };
            
            const cancelPress = () => {
                if (pressTimer) {
                    clearTimeout(pressTimer);
                    pressTimer = null;
                }
            };
            
            // 触摸事件
            element.addEventListener('touchstart', startPress, { passive: true });
            
            element.addEventListener('touchmove', (e) => {
                // 检查是否移动了足够的距离
                if (e.type === 'touchmove') {
                    const touchX = e.touches[0].clientX;
                    const touchY = e.touches[0].clientY;
                    const deltaX = Math.abs(touchX - touchStartX);
                    const deltaY = Math.abs(touchY - touchStartY);
                    
                    // 如果移动超过10像素，取消长按
                    if (deltaX > 10 || deltaY > 10) {
                        touchMoved = true;
                        cancelPress();
                    }
                }
            });
            
            element.addEventListener('touchend', () => {
                cancelPress();
            });
            
            element.addEventListener('touchcancel', cancelPress);
            
            // 鼠标事件
            element.addEventListener('mousedown', startPress);
            element.addEventListener('mouseup', cancelPress);
            element.addEventListener('mouseleave', cancelPress);
            
            // 阻止长按时的默认菜单
            element.addEventListener('contextmenu', (e) => {
                e.preventDefault();
                if (!isLongPress) {
                    showMessageMenu(e, message);
                }
            });
        }

        // 显示消息菜单
        function showMessageMenu(event, message) {
            // 移除已存在的菜单
            const existingMenu = document.querySelector('.message-menu');
            if (existingMenu) {
                existingMenu.parentNode.remove();
            }
            
            // 找到消息元素
            const messageElement = event.target.closest('.message');
            if (!messageElement) return;
            
            // 获取消息元素的位置
            const rect = messageElement.getBoundingClientRect();
            
            // 创建菜单容器
            const menuContainer = document.createElement('div');
            menuContainer.className = 'message-menu-container';
            
            // 创建菜单
            const menu = document.createElement('div');
            menu.className = 'message-menu';
            
            // 添加复制选项
            const copyItem = document.createElement('div');
            copyItem.className = 'menu-item copy';
            copyItem.textContent = '复制';
            copyItem.onclick = () => {
                copyMessage(message);
                menuContainer.remove();
            };
            
            // 添加撤回选项
            const recallItem = document.createElement('div');
            recallItem.className = 'menu-item recall';
            recallItem.textContent = '撤回';
            recallItem.onclick = () => {
                recallMessage(message.id);
                menuContainer.remove();
            };
            
            // 添加删除选项
            const deleteItem = document.createElement('div');
            deleteItem.className = 'menu-item delete';
            deleteItem.textContent = '删除';
            deleteItem.onclick = () => {
                deleteMessage(message.id);
                menuContainer.remove();
            };
            
            menu.appendChild(copyItem);
            menu.appendChild(recallItem);
            menu.appendChild(deleteItem);
            menuContainer.appendChild(menu);
            
            // 设置菜单位置
            menuContainer.style.top = `${rect.bottom + window.scrollY}px`;
            
            // 根据消息的位置（左对齐或右对齐）来设置菜单对齐方式
            if (messageElement.classList.contains('sent')) {
                // 发送的消息（右对齐），菜单整体向左移动
                menuContainer.style.left = `${rect.right - 180 + window.scrollX}px`;
                menuContainer.style.justifyContent = 'flex-end';
            } else {
                // 接收的消息（左对齐），菜单也左对齐
                menuContainer.style.left = `${rect.left + window.scrollX}px`;
                menuContainer.style.justifyContent = 'flex-start';
            }
            
            // 将菜单容器添加到body中
            document.body.appendChild(menuContainer);
            
            // 立即显示菜单
            menu.classList.add('show');
            
            // 点击其他地方关闭菜单
            const closeMenu = (e) => {
                if (!menuContainer.contains(e.target)) {
                    menuContainer.remove();
                    document.removeEventListener('click', closeMenu);
                    document.removeEventListener('touchstart', closeMenu);
                }
            };
            
            // 延迟添加事件监听器，避免立即触发
            setTimeout(() => {
                document.addEventListener('click', closeMenu);
                document.addEventListener('touchstart', closeMenu);
            }, 100);
        }

        // 撤回消息
        function recallMessage(messageId) {
            const message = appState.messageHistory.find(msg => msg.id === messageId);
            if (!message) return;
            
            // 发送撤回请求到服务器
            if (appState.connectedUser && appState.websocket && appState.websocket.readyState === WebSocket.OPEN) {
                const recallMessage = {
                    type: 'recall_message',
                    data: {
                        senderId: appState.currentUser.id,
                        targetUserId: appState.connectedUser.id,
                        messageId: messageId,
                        messageTimestamp: message.timestamp.getTime(), // 使用消息时间戳来匹配
                        timestamp: new Date().toISOString()
                    }
                };
                
                const success = sendServerMessage(recallMessage);
                if (success) {
                    console.log('发送撤回消息:', recallMessage);
                }
            }
            
            // 本地立即显示撤回状态
            performMessageRecall(messageId);
        }
        
        // 执行消息撤回显示
        function performMessageRecall(messageId) {
            const messageElement = document.querySelector(`[data-message-id="${messageId}"]`);
            if (messageElement) {
                const contentElement = messageElement.querySelector('.message-content');
                
                // 清除原有内容
                contentElement.innerHTML = '';
                
                // 添加撤回提示
                const recallText = document.createElement('div');
                recallText.className = 'message-text';
                recallText.textContent = '消息已撤回';
                recallText.style.fontStyle = 'italic';
                recallText.style.opacity = '0.7';
                
                const timeElement = document.createElement('div');
                timeElement.className = 'message-time';
                timeElement.textContent = formatTime(new Date());
                
                contentElement.appendChild(recallText);
                contentElement.appendChild(timeElement);
                
                // 更新消息历史
                const message = appState.messageHistory.find(msg => msg.id === messageId);
                if (message) {
                    message.text = '消息已撤回';
                    message.isRecalled = true;
                }
            }
        }

        // 复制消息
        function copyMessage(message) {
            let textToCopy = '';
            
            // 根据消息类型提取要复制的文本
            if (message.type === 'text' || message.type === 'system') {
                textToCopy = message.text;
            } else if (message.type === 'image') {
                textToCopy = `[图片] ${message.fileName || ''}`;
            } else if (message.type === 'video') {
                textToCopy = `[视频] ${message.fileName || ''}`;
            } else if (message.type === 'file') {
                textToCopy = `[文件] ${message.fileName || ''}`;
            } else if (message.type === 'voice') {
                textToCopy = `[语音] 时长: ${message.duration || 0}秒`;
            } else {
                textToCopy = message.text || '[不支持的消息类型]';
            }
            
            // 创建临时文本区域
            const tempTextArea = document.createElement('textarea');
            tempTextArea.value = textToCopy;
            tempTextArea.style.position = 'fixed';
            tempTextArea.style.opacity = '0';
            tempTextArea.style.left = '-9999px';
            document.body.appendChild(tempTextArea);
            
            try {
                // 选择并复制文本
                tempTextArea.select();
                tempTextArea.setSelectionRange(0, 99999); // 移动设备兼容
                
                const successful = document.execCommand('copy');
                document.body.removeChild(tempTextArea);
                
                if (successful) {
                    showNotification('消息已复制到剪贴板', 'success');
                } else {
                    // 如果execCommand失败，尝试使用现代API
                    if (navigator.clipboard && window.isSecureContext) {
                        navigator.clipboard.writeText(textToCopy)
                            .then(() => {
                                showNotification('消息已复制到剪贴板', 'success');
                            })
                            .catch(err => {
                                console.error('复制失败:', err);
                                showNotification('复制失败，请手动复制', 'error');
                            });
                    } else {
                        showNotification('复制失败，请手动复制', 'error');
                    }
                }
            } catch (err) {
                console.error('复制失败:', err);
                document.body.removeChild(tempTextArea);
                
                // 尝试使用现代API作为后备
                if (navigator.clipboard && window.isSecureContext) {
                    navigator.clipboard.writeText(textToCopy)
                        .then(() => {
                            showNotification('消息已复制到剪贴板', 'success');
                        })
                        .catch(err => {
                            console.error('复制失败:', err);
                            showNotification('复制失败，请手动复制', 'error');
                        });
                } else {
                    showNotification('复制失败，请手动复制', 'error');
                }
            }
        }

        // 删除消息
        function deleteMessage(messageId) {
            const messageElement = document.querySelector(`[data-message-id="${messageId}"]`);
            if (messageElement) {
                messageElement.remove();
                
                // 从消息历史中移除
                appState.messageHistory = appState.messageHistory.filter(msg => msg.id !== messageId);
                
                // 检查是否需要显示空状态
                const container = document.getElementById('messagesContainer');
                if (container.children.length === 0) {
                    showEmptyState();
                }
            }
        }

        // 显示空状态
        function showEmptyState() {
            const container = document.getElementById('messagesContainer');
            const emptyState = document.createElement('div');
            emptyState.className = 'empty-state';
            emptyState.innerHTML = `
                <div class="empty-icon">💬</div>
                <div class="empty-title">暂无消息</div>
                <div class="empty-text">开始你的第一条消息吧</div>
            `;
            container.appendChild(emptyState);
        }

        

        // 发送图片
        function attachImage() {
            if (!appState.isConnected) {
                showNotification('请先建立连接', 'warning');
                return;
            }
            document.getElementById('imageInput').click();
        }

        function processImage(event) {
            const file = event.target.files[0];
            if (file) {
                // 检查文件类型
                if (!file.type.startsWith('image/')) {
                    showNotification('请选择图片文件', 'warning');
                    return;
                }
                
                if (!appState.isConnected) {
                    showNotification('请先建立连接', 'warning');
                    return;
                }
                
                if (!appState.isServerConnected) {
                    showNotification('服务器连接已断开，无法发送图片', 'warning');
                    return;
                }
                
                // 获取复选框状态
                const isFlash = document.getElementById('flashCheckbox').checked;
                const shouldDestroy = document.getElementById('destroyCheckbox').checked;
                
                // 不重置复选框，保持用户选择
                
                // 读取图片为base64
                const reader = new FileReader();
                reader.onload = function(e) {
                    const base64Data = e.target.result;
                    const now = new Date();
                    const message = {
                        id: Date.now(),
                        text: '',
                        sender: appState.currentUser.id,
                        timestamp: now,
                        type: 'image',
                        fileName: file.name,
                        fileSize: file.size,
                        content: base64Data,
                        isFlash: isFlash,
                        destroyTime: shouldDestroy ? now.getTime() + 13000 : null // 勾选13秒自动销毁时设置销毁时间
                    };
                    
                    // 发送消息到服务器
                    const success = sendServerMessage({
                        type: 'chat_message',
                        data: {
                            senderId: appState.currentUser.id,
                            targetUserId: appState.connectedUser.id,
                            text: '',
                            timestamp: now.toISOString(),
                            type: 'image',
                            fileName: file.name,
                            fileSize: file.size,
                            content: base64Data,
                            isFlash: isFlash,
                            destroyTime: shouldDestroy ? new Date(now.getTime() + 13000).toISOString() : null
                        }
                    });
                    
                    if (!success) {
                        showNotification('发送图片失败，请检查网络连接', 'error');
                        return;
                    }
                    
                    appState.messageHistory.push(message);
                    displayImageMessage(message, 'sent');
                    
                    // 更新用户列表中的最后消息
                    updateUserLastMessage('🖼️ 图片');
                    
                    // 显示提示
                    if (isFlash) {
                        showNotification('闪照已发送，查看后自动销毁', 'info');
                    } else if (shouldDestroy) {
                        showNotification('图片将在13秒后自动销毁', 'info');
                    }
                };
                reader.readAsDataURL(file);
            }
        }

        // 发送视频
        function attachVideo() {
            if (!appState.isConnected) {
                showNotification('请先建立连接', 'warning');
                return;
            }
            document.getElementById('videoInput').click();
        }

        function processVideo(event) {
            const file = event.target.files[0];
            if (file) {
                // 检查文件类型
                if (!file.type.startsWith('video/')) {
                    showNotification('请选择视频文件', 'warning');
                    return;
                }
                
                if (!appState.isConnected) {
                    showNotification('请先建立连接', 'warning');
                    return;
                }
                
                if (!appState.isServerConnected) {
                    showNotification('服务器连接已断开，无法发送视频', 'warning');
                    return;
                }
                
                // 显示处理中提示
                showNotification('正在处理视频文件，请稍候...', 'info');
                
                // 读取视频为base64（因为WebSocket传输需要字符串）
                const reader = new FileReader();
                reader.onload = function(e) {
                    const base64Data = e.target.result;
                    
                    // 创建视频元素获取视频信息
                    const video = document.createElement('video');
                    video.src = base64Data;
                    video.preload = 'metadata';
                    
                    video.onloadedmetadata = function() {
                        // 获取视频时长
                        const duration = video.duration;
                        
                        // 获取复选框状态
                        const isFlash = document.getElementById('flashCheckbox').checked;
                        const shouldDestroy = document.getElementById('destroyCheckbox').checked;
                        
                        // 暂时隐藏消息选项，发送后会重新显示
                        document.getElementById('messageOptions').style.display = 'none';
                        
                        // 创建消息对象，使用base64数据
                        const now = new Date();
                        const message = {
                            id: Date.now(),
                            text: '',
                            sender: appState.currentUser.id,
                            timestamp: now,
                            type: 'video',
                            fileName: file.name,
                            fileSize: file.size,
                            content: base64Data,
                            duration: duration,
                            isFlash: false, // 视频不支持闪照功能
                            destroyTime: shouldDestroy ? now.getTime() + 13000 : null
                        };
                        
                        // 发送消息到服务器
                        const success = sendServerMessage({
                            type: 'chat_message',
                            data: {
                                senderId: appState.currentUser.id,
                                targetUserId: appState.connectedUser.id,
                                text: '',
                                timestamp: now.toISOString(),
                                type: 'video',
                                fileName: file.name,
                                fileSize: file.size,
                                content: base64Data,
                                duration: duration,
                                isFlash: false,
                                destroyTime: shouldDestroy ? new Date(now.getTime() + 13000).toISOString() : null
                            }
                        });
                        
                        if (!success) {
                            showNotification('发送视频失败，请检查网络连接', 'error');
                            document.getElementById('messageOptions').style.display = 'block';
                            return;
                        }
                        
                        appState.messageHistory.push(message);
                        displayVideoMessage(message, 'sent');
                        
                        // 更新用户列表中的最后消息
                        updateUserLastMessage('🎬 视频');
                        
                        // 显示提示
                        if (shouldDestroy) {
                            showNotification('视频将在13秒后自动销毁', 'info');
                        } else {
                            showNotification('视频发送成功', 'success');
                        }
                        
                        // 重新显示消息选项
                        document.getElementById('messageOptions').style.display = 'block';
                    };
                    
                    video.onerror = function() {
                        showNotification('视频文件读取失败，请重试', 'error');
                        // 重新显示消息选项
                        document.getElementById('messageOptions').style.display = 'block';
                    };
                };
                
                reader.readAsDataURL(file);
            }
        }

        // 发送文件
        function attachFile() {
            if (!appState.isConnected) {
                showNotification('请先建立连接', 'warning');
                return;
            }
            document.getElementById('fileInput').click();
        }

        function processFile(event) {
            const file = event.target.files[0];
            if (file) {
                if (!appState.isConnected) {
                    showNotification('请先建立连接', 'warning');
                    return;
                }
                
                if (!appState.isServerConnected) {
                    showNotification('服务器连接已断开，无法发送文件', 'warning');
                    return;
                }
                
                // 获取复选框状态
                const isFlash = document.getElementById('flashCheckbox').checked;
                const shouldDestroy = document.getElementById('destroyCheckbox').checked;
                
                // 文件不支持闪照功能，忽略闪照选项
                
                // 暂时隐藏消息选项，发送后会重新显示
                document.getElementById('messageOptions').style.display = 'none';
                
                // 读取文件为base64
                const reader = new FileReader();
                reader.onload = function(e) {
                    const base64Data = e.target.result;
                    const now = new Date();
                    const message = {
                        id: Date.now(),
                        text: `📎 文件: ${file.name}`,
                        sender: appState.currentUser.id,
                        timestamp: now,
                        type: 'file',
                        fileName: file.name,
                        fileSize: file.size,
                        content: base64Data, // 添加文件内容
                        isFlash: false, // 文件不支持闪照功能
                        destroyTime: shouldDestroy ? now.getTime() + 13000 : null
                    };
                    
                    // 发送消息到服务器
                    const success = sendServerMessage({
                        type: 'chat_message',
                        data: {
                            senderId: appState.currentUser.id,
                            targetUserId: appState.connectedUser.id,
                            text: `📎 文件: ${file.name}`,
                            timestamp: now.toISOString(),
                            type: 'file',
                            fileName: file.name,
                            fileSize: file.size,
                            content: base64Data,
                            isFlash: false,
                            destroyTime: shouldDestroy ? new Date(now.getTime() + 13000).toISOString() : null
                        }
                    });
                    
                    if (!success) {
                        showNotification('发送文件失败，请检查网络连接', 'error');
                        document.getElementById('messageOptions').style.display = 'block';
                        return;
                    }
                    
                    appState.messageHistory.push(message);
                    displayFileMessage(message, 'sent');
                    
                    // 更新用户列表中的最后消息
                    updateUserLastMessage('📎 文件');
                    
                    // 显示提示
                    if (shouldDestroy) {
                        showNotification('文件将在13秒后自动销毁', 'info');
                    } else {
                        showNotification('文件发送成功', 'success');
                    }
                    
                    // 重新显示消息选项
                    document.getElementById('messageOptions').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        }

        // 显示文件消息
        function displayFileMessage(message, direction) {
            const container = document.getElementById('messagesContainer');
            
            // 移除空状态
            const emptyState = container.querySelector('.empty-state');
            if (emptyState) {
                emptyState.remove();
            }
            
            const messageElement = document.createElement('div');
            messageElement.className = `message ${direction}`;
            messageElement.dataset.messageId = message.id;
            messageElement.dataset.messageId = message.id;
            
            const contentElement = document.createElement('div');
            contentElement.className = 'message-content';
            
            // 倒计时变量，后面使用
            let countdownElements = null;
            
            // 如果消息有销毁时间，准备倒计时元素但不立即添加
            if (message.destroyTime) {
                countdownElements = {
                    ring: null,
                    timer: null
                };
            }
            
            const textElement = document.createElement('div');
            textElement.className = 'message-text';
            // 使用innerHTML而不是textContent，保留换行符
            textElement.innerHTML = message.text.replace(/\n/g, '<br>');
            
            const fileElement = document.createElement('div');
            fileElement.className = 'file-message';
            
            // 为接收到的文件添加下载按钮
            const downloadButton = direction === 'received' ? 
                `<div class="download-btn" onclick="downloadFile('${message.fileName}', '${message.content || ''}')">↓</div>` : '';
            
            // 处理文件名，手动插入换行符
            let fileName = message.fileName;
            const maxCharsPerLine = 30; // 每行最大字符数
            let formattedFileName = '';
            
            for (let i = 0; i < fileName.length; i++) {
                formattedFileName += fileName[i];
                if ((i + 1) % maxCharsPerLine === 0 && i < fileName.length - 1) {
                    formattedFileName += '\n';
                }
            }
            
            fileElement.innerHTML = `
                <div class="file-icon">${message.type === 'image' ? '🖼️' : message.type === 'video' ? '🎬' : '📎'}</div>
                <div class="file-details">
                    <div class="file-name" style="white-space: pre-line;">${formattedFileName}</div>
                    ${message.fileSize ? `<div class="file-size">${formatFileSize(message.fileSize)}</div>` : ''}
                </div>
                ${downloadButton}
            `;
            
            const timeElement = document.createElement('div');
            timeElement.className = 'message-time';
            timeElement.textContent = formatTime(message.timestamp);
            
            contentElement.appendChild(textElement);
            contentElement.appendChild(fileElement);
            contentElement.appendChild(timeElement);
            messageElement.appendChild(contentElement);
            
            // 添加长按事件
            addLongPressEvent(messageElement, message);
            
            container.appendChild(messageElement);
            
            // 如果有倒计时，现在添加到消息侧边
            if (countdownElements && message.destroyTime) {
                // 创建倒计时容器
                const countdownContainer = document.createElement('div');
                countdownContainer.className = 'countdown-container';
                countdownContainer.style.cssText = `
                    display: flex;
                    align-items: center;
                    gap: 5px;
                    position: absolute;
                    top: 50%;
                    transform: translateY(-50%);
                    ${direction === 'sent' ? 'left: -45px;' : 'right: -45px;'}
                `;
                
                const countdownRing = document.createElement('div');
                countdownRing.className = 'countdown-ring';
                countdownRing.innerHTML = `
                    <svg>
                        <circle class="background" cx="10" cy="10" r="8"></circle>
                        <circle class="progress" cx="10" cy="10" r="8" 
                                stroke-dasharray="${2 * Math.PI * 8}" 
                                stroke-dashoffset="0"></circle>
                    </svg>
                `;
                
                const timerElement = document.createElement('div');
                timerElement.className = 'message-timer';
                timerElement.textContent = '13s';
                
                countdownContainer.appendChild(countdownRing);
                countdownContainer.appendChild(timerElement);
                
                // 将倒计时添加到消息元素中
                messageElement.appendChild(countdownContainer);
                messageElement.style.position = 'relative';
                
                // 启动倒计时
                startMessageCountdown(message.id, message.destroyTime, timerElement, countdownRing.querySelector('.progress'));
            }
            
            // 延迟滚动到底部，确保DOM更新完成
            setTimeout(() => {
                container.scrollTop = container.scrollHeight;
            }, 100);
        }
        
        // 下载文件函数
        function downloadFile(fileName, fileContent) {
            // 如果有文件内容，创建下载链接
            if (fileContent) {
                try {
                    // 创建下载链接
                    const link = document.createElement('a');
                    link.href = fileContent;
                    link.download = fileName;
                    
                    // 对于base64数据，需要设置正确的属性
                    if (fileContent.startsWith('data:')) {
                        link.setAttribute('target', '_blank');
                    }
                    
                    // 触发下载
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    
                    showNotification('文件下载已开始', 'success');
                } catch (error) {
                    console.error('下载失败:', error);
                    showNotification('下载失败，请重试', 'error');
                }
            } else {
                // 如果没有文件内容，显示提示
                showNotification('文件内容不可用', 'warning');
            }
        }

// 语音通话
        function startVoiceCall() {
            if (!appState.isConnected) {
                showNotification('请先建立连接', 'warning');
                return;
            }
            
            // 检查是否已经在通话中
            if (appState.isInCall) {
                showNotification('已经在通话中', 'warning');
                return;
            }
            
            // 发送语音通话请求
            const requestData = {
                type: 'voice_call_request',
                data: {
                    userId: appState.currentUser.id,
                    displayName: appState.currentUser.displayName,
                    targetUserId: appState.connectedUser.id,
                    requestId: Date.now().toString()
                }
            };
            console.log('发送语音通话请求:', requestData);
            
            const success = sendServerMessage(requestData);
            
            if (!success) {
                showNotification('发送通话请求失败，请检查网络连接', 'error');
                return;
            }
            
            // 设置通话状态
            appState.isInCall = true;
            appState.callType = 'voice';
            appState.isMuted = false;
            appState.isCallInitiator = true; // 标记为通话发起方
            appState.callStartTime = Date.now();
            console.log('📞 语音通话开始');
            
            // 设置超时，如果60秒内对方没有响应
            appState.callTimeout = setTimeout(() => {
                if (appState.isInCall && appState.isCallInitiator && !appState.rtcPeerConnection) {
                    console.log('⏰ 60秒超时，但通话继续');
                    showNotification('对方未响应，通话继续', 'warning');
                    // 不再调用endCall()，保持通话状态
                }
            }, 60000);
        }
        
        // 创建等待接听界面
        function createWaitingCallUI(callType) {
            const chatArea = document.querySelector('.chat-area');
            
            // 创建等待通话容器
            const waitingContainer = document.createElement('div');
            waitingContainer.className = 'waiting-call-container';
            waitingContainer.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, #1a1a2e, #16213e);
                z-index: 1000;
                display: flex;
                flex-direction: column;
                color: white;
                justify-content: center;
                align-items: center;
            `;
            
            const callIcon = callType === 'voice' ? '📞' : '📹';
            const callText = callType === 'voice' ? '语音通话' : '视频通话';
            
            waitingContainer.innerHTML = `
                <div class="waiting-call-header" style="text-align: center; margin-bottom: 40px;">
                    <div style="font-size: 48px; margin-bottom: 20px;">${callIcon}</div>
                    <div style="font-size: 24px; font-weight: 600; margin-bottom: 10px;">正在呼叫...</div>
                    <div style="font-size: 18px; opacity: 0.8;">${appState.connectedUser.displayName}</div>
                    <div style="font-size: 14px; opacity: 0.6; margin-top: 5px;">ID: ${appState.connectedUser.id}</div>
                </div>
                <div class="waiting-animation" style="margin-bottom: 40px;">
                    <div style="display: flex; align-items: center; gap: 4px;">
                        <div class="waiting-dot" style="width: 12px; height: 12px; background: #4ecdc4; border-radius: 50%; animation: waitingPulse 1.4s infinite ease-in-out both;"></div>
                        <div class="waiting-dot" style="width: 12px; height: 12px; background: #4ecdc4; border-radius: 50%; animation: waitingPulse 1.4s infinite ease-in-out both; animation-delay: 0.2s;"></div>
                        <div class="waiting-dot" style="width: 12px; height: 12px; background: #4ecdc4; border-radius: 50%; animation: waitingPulse 1.4s infinite ease-in-out both; animation-delay: 0.4s;"></div>
                    </div>
                </div>
                <div class="waiting-controls">
                    <button class="waiting-cancel-btn" onclick="endCall()" style="
                        background: var(--danger-color);
                        color: white;
                        border: none;
                        padding: 15px 30px;
                        border-radius: 30px;
                        font-size: 16px;
                        font-weight: 600;
                        cursor: pointer;
                        transition: all 0.3s ease;
                        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
                    ">取消通话</button>
                </div>
            `;
            
            // 添加动画样式
            const style = document.createElement('style');
            style.textContent = `
                @keyframes waitingPulse {
                    0%, 80%, 100% {
                        transform: scale(0);
                        opacity: 0.5;
                    }
                    40% {
                        transform: scale(1);
                        opacity: 1;
                    }
                }
            `;
            document.head.appendChild(style);
            
            // 添加到聊天区域
            chatArea.appendChild(waitingContainer);
        }

        // 创建来电界面
        function createIncomingCallUI(callType, callerInfo) {
            const chatArea = document.querySelector('.chat-area');
            
            // 创建来电容器
            const incomingContainer = document.createElement('div');
            incomingContainer.className = 'incoming-call-container';
            incomingContainer.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, #1a1a2e, #16213e);
                z-index: 1000;
                display: flex;
                flex-direction: column;
                color: white;
                justify-content: center;
                align-items: center;
            `;
            
            const callIcon = callType === 'voice' ? '📞' : '📹';
            const callText = callType === 'voice' ? '语音通话' : '视频通话';
            
            incomingContainer.innerHTML = `
                <div class="incoming-call-header" style="text-align: center; margin-bottom: 40px;">
                    <div style="font-size: 64px; margin-bottom: 20px; animation: ringAnimation 1s infinite;">${callIcon}</div>
                    <div style="font-size: 24px; font-weight: 600; margin-bottom: 10px;">来电</div>
                    <div style="font-size: 20px; opacity: 0.9;">${callerInfo.displayName}</div>
                    <div style="font-size: 14px; opacity: 0.6; margin-top: 5px;">ID: ${callerInfo.id}</div>
                </div>
                <div class="incoming-animation" style="margin-bottom: 40px;">
                    <div style="display: flex; align-items: center; gap: 4px;">
                        <div class="incoming-dot" style="width: 12px; height: 12px; background: #e94560; border-radius: 50%; animation: incomingPulse 1s infinite ease-in-out both;"></div>
                        <div class="incoming-dot" style="width: 12px; height: 12px; background: #e94560; border-radius: 50%; animation: incomingPulse 1s infinite ease-in-out both; animation-delay: 0.2s;"></div>
                        <div class="incoming-dot" style="width: 12px; height: 12px; background: #e94560; border-radius: 50%; animation: incomingPulse 1s infinite ease-in-out both; animation-delay: 0.4s;"></div>
                    </div>
                </div>
                <div class="incoming-controls" style="display: flex; gap: 30px;">
                    <button class="incoming-reject-btn" onclick="rejectCall('${callType}')" style="
                        background: var(--danger-color);
                        color: white;
                        border: none;
                        padding: 15px 30px;
                        border-radius: 30px;
                        font-size: 16px;
                        font-weight: 600;
                        cursor: pointer;
                        transition: all 0.3s ease;
                        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
                    ">拒接</button>
                    <button class="incoming-accept-btn" onclick="acceptCall('${callType}')" style="
                        background: var(--success-color);
                        color: white;
                        border: none;
                        padding: 15px 30px;
                        border-radius: 30px;
                        font-size: 16px;
                        font-weight: 600;
                        cursor: pointer;
                        transition: all 0.3s ease;
                        box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);
                    ">接听</button>
                </div>
            `;
            
            // 添加动画样式
            const style = document.createElement('style');
            style.textContent = `
                @keyframes incomingPulse {
                    0%, 80%, 100% {
                        transform: scale(0);
                        opacity: 0.5;
                    }
                    40% {
                        transform: scale(1.2);
                        opacity: 1;
                    }
                }
                @keyframes ringAnimation {
                    0%, 100% {
                        transform: rotate(0deg);
                    }
                    10%, 30% {
                        transform: rotate(-10deg);
                    }
                    20%, 40% {
                        transform: rotate(10deg);
                    }
                }
            `;
            document.head.appendChild(style);
            
            // 添加到聊天区域
            chatArea.appendChild(incomingContainer);
            
            // 播放来电铃声
            playRingtone();
            
            // 设置超时，如果60秒内用户没有响应
            appState.callTimeout = setTimeout(() => {
                if (!appState.isCallInitiator && !appState.isInCall) {
                    console.log('⏰ 60秒超时，但通话继续');
                    showNotification('超时，但通话继续', 'warning');
                    // 不再调用rejectCall()，保持通话状态
                }
            }, 60000);
        }

        // 创建语音通话界面
        function createVoiceCallUI() {
            const chatArea = document.querySelector('.chat-area');
            
            // 创建语音通话容器
            const voiceContainer = document.createElement('div');
            voiceContainer.className = 'voice-call-container';
            voiceContainer.innerHTML = `
                <div class="voice-call-header">
                    <div class="voice-call-timer" id="voiceCallTimer">00:00</div>
                    <div class="voice-call-status">语音通话中...</div>
                </div>
                <div class="voice-call-main">
                    <div class="voice-avatar">👤</div>
                    <div class="voice-partner-name">${appState.connectedUser.displayName}</div>
                    <div class="voice-partner-id">ID: ${appState.connectedUser.id}</div>
                    <div class="voice-wave-container">
                        <div class="voice-wave">
                            <div class="voice-wave-bar"></div>
                            <div class="voice-wave-bar"></div>
                            <div class="voice-wave-bar"></div>
                            <div class="voice-wave-bar"></div>
                            <div class="voice-wave-bar"></div>
                            <div class="voice-wave-bar"></div>
                            <div class="voice-wave-bar"></div>
                            <div class="voice-wave-bar"></div>
                        </div>
                    </div>
                </div>
                <div class="voice-controls">
                    <button class="voice-control-btn voice-mute-btn" id="voiceMuteBtn" onclick="toggleVoiceMute()">
                        🎤
                    </button>
                    <button class="voice-control-btn voice-speaker-btn" id="voiceSpeakerBtn" onclick="toggleSpeaker()">
                        🔊
                    </button>
                    <button class="voice-control-btn voice-end-btn" onclick="endCall()">
                        📞
                    </button>
                </div>
            `;
            
            // 添加到聊天区域
            chatArea.appendChild(voiceContainer);
        }
        
        // 切换语音静音
        function toggleVoiceMute() {
            if (!appState.localStream) return;
            
            appState.isMuted = !appState.isMuted;
            const audioTracks = appState.localStream.getAudioTracks();
            audioTracks.forEach(track => {
                track.enabled = !appState.isMuted;
            });
            
            // 控制音频监听
            if (appState.gainNode) {
                if (appState.isMuted) {
                    // 静音时断开连接
                    try {
                        appState.gainNode.disconnect();
                    } catch (e) {
                        console.error('断开音频节点失败:', e);
                    }
                } else {
                    // 开启时重新连接
                    try {
                        appState.gainNode.connect(appState.audioContext.destination);
                    } catch (e) {
                        console.error('连接音频节点失败:', e);
                    }
                }
            }
            
            const muteBtn = document.getElementById('voiceMuteBtn');
            if (muteBtn) {
                if (appState.isMuted) {
                    muteBtn.innerHTML = '🔇';
                    muteBtn.classList.add('muted');
                } else {
                    muteBtn.innerHTML = '🎤';
                    muteBtn.classList.remove('muted');
                }
            }
            
            // 播放提示音（仅在取消静音时播放，避免静音状态下听不到）
            if (!appState.isMuted) {
                playNotificationSound('unmuted');
            }
        }
        
        // 切换扬声器
        function toggleSpeaker() {
            appState.isSpeakerOn = !appState.isSpeakerOn;
            
            const speakerBtn = document.getElementById('voiceSpeakerBtn');
            if (speakerBtn) {
                if (appState.isSpeakerOn) {
                    speakerBtn.innerHTML = '🔇';
                    speakerBtn.classList.add('muted');
                } else {
                    speakerBtn.innerHTML = '🔊';
                    speakerBtn.classList.remove('muted');
                }
            }
            
            // 控制音频监听音量
            if (appState.gainNode) {
                // 通过调整gainNode的gain值来控制音量
                appState.gainNode.gain.value = appState.isSpeakerOn ? 0 : 0.2;
            }
            
            // 播放提示音
            playNotificationSound(appState.isSpeakerOn ? 'speaker_on' : 'speaker_off');
        }
        
        // 接听来电
        function acceptCall(callType) {
            // 清除超时
            if (appState.callTimeout) {
                clearTimeout(appState.callTimeout);
                appState.callTimeout = null;
            }
            
            // 停止铃声
            stopRingtone();
            
            // 移除来电界面
            const incomingContainer = document.querySelector('.incoming-call-container');
            if (incomingContainer) {
                incomingContainer.remove();
            }
            
            // 发送接受通话的消息
            const responseType = callType === 'voice' ? 'voice_call_response' : 'video_call_response';
            sendServerMessage({
                type: responseType,
                data: {
                    userId: appState.currentUser.id,
                    targetUserId: appState.connectedUser.id,
                    accepted: true,
                    requestId: appState.currentCallRequestId
                }
            });
            
            // 设置通话状态
            appState.isInCall = true;
            appState.callType = callType;
            appState.isCallInitiator = false; // 标记为通话接收方
            appState.callStartTime = Date.now();
            console.log(`📞 ${callType === 'voice' ? '语音' : '视频'}通话开始（接听）`);
            
            // 根据通话类型创建相应的界面
            if (callType === 'voice') {
                createVoiceCallUI();
                appState.isMuted = false;
                
                // 请求麦克风权限
                if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                    navigator.mediaDevices.getUserMedia({ audio: true })
                        .then(stream => {
                            appState.localStream = stream;
                            
                            // 创建音频上下文用于实时监听自己的声音
                            appState.audioContext = new (window.AudioContext || window.webkitAudioContext)();
                            appState.mediaStreamSource = appState.audioContext.createMediaStreamSource(stream);
                            appState.gainNode = appState.audioContext.createGain();
                            
                            // 设置音量
                            appState.gainNode.gain.value = 0.2; // 设置较低的音量，避免回声
                            
                            // 连接音频节点
                            appState.mediaStreamSource.connect(appState.gainNode);
                            appState.gainNode.connect(appState.audioContext.destination);
                            
                            // 开始通话计时
                            startCallTimer();
                            updateVoiceCallUI();
                            
                            // 初始化WebRTC连接
                            initializeWebRTC(callType);
                        })
                        .catch(err => {
                            console.error('无法访问麦克风:', err);
                            showNotification('无法访问麦克风，请检查权限设置', 'error');
                            endCall();
                        });
                } else {
                    showNotification('浏览器不支持语音通话', 'error');
                    endCall();
                }
            } else if (callType === 'video') {
                console.log('接听视频通话，创建视频界面');
                createVideoCallUI();
                appState.isVideoMicMuted = false;
                
                // 先初始化WebRTC连接，再请求摄像头权限
                initializeWebRTC(callType);
                
                // 开始通话计时，不等待摄像头权限
                startCallTimer();
                updateCallUI();
                
                // 请求摄像头和麦克风权限
                if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                    navigator.mediaDevices.getUserMedia({ 
                        video: { 
                            width: { ideal: 1280 },
                            height: { ideal: 720 },
                            facingMode: 'user'
                        }, 
                        audio: true
                    })
                        .then(stream => {
                            appState.localStream = stream;
                            
                            // 将本地流添加到WebRTC连接
                            if (appState.rtcPeerConnection) {
                                appState.localStream.getTracks().forEach(track => {
                                    appState.rtcPeerConnection.addTrack(track, appState.localStream);
                                });
                            }
                            
                            // 立即设置本地视频
                            const localVideo = document.getElementById('localVideo');
                            if (localVideo) {
                                try {
                                    // 使用安全的视频设置函数
                                    appState.setVideoStream(localVideo, stream);
                                    // 前置摄像头默认镜像显示
                                    localVideo.style.transform = 'scaleX(-1)';
                                } catch (error) {
                                    console.error('❌ 设置本地视频流失败:', error);
                                }
                            } else {
                                console.error('❌ 接听方找不到本地视频元素');
                            }
                            
                            // 创建音频上下文用于实时监听自己的声音
                            appState.audioContext = new (window.AudioContext || window.webkitAudioContext)();
                            appState.mediaStreamSource = appState.audioContext.createMediaStreamSource(stream);
                            appState.gainNode = appState.audioContext.createGain();
                            
                            // 创建增益节点以控制音量
                            appState.gainNode.gain.value = 0.2; // 设置较低的音量，避免回声
                            
                            // 连接音频节点
                            appState.mediaStreamSource.connect(appState.gainNode);
                            appState.gainNode.connect(appState.audioContext.destination);
                            
                            // 更新麦克风按钮状态
                            updateVideoMicButton();
                            
                            // 添加方向变化监听
                            window.addEventListener('orientationchange', handleOrientationChange);
                        })
                        .catch(err => {
                            console.error('无法访问摄像头或麦克风:', err);
                            // 不立即结束通话，而是显示提示并继续音频通话
                            showNotification('无法访问摄像头，将进行语音通话', 'warning');
                            
                            // 尝试只获取麦克风权限
                            navigator.mediaDevices.getUserMedia({ audio: true })
                                .then(audioStream => {
                                    appState.localStream = audioStream;
                                    
                                    // 将音频流添加到WebRTC连接
                                    if (appState.rtcPeerConnection) {
                                        audioStream.getTracks().forEach(track => {
                                            appState.rtcPeerConnection.addTrack(track, audioStream);
                                        });
                                        console.log('音频流已添加到WebRTC连接');
                                    }
                                    
                                    // 创建音频上下文
                                    appState.audioContext = new (window.AudioContext || window.webkitAudioContext)();
                                    appState.mediaStreamSource = appState.audioContext.createMediaStreamSource(audioStream);
                                    appState.gainNode = appState.audioContext.createGain();
                                    appState.gainNode.gain.value = 0.2;
                                    appState.mediaStreamSource.connect(appState.gainNode);
                                    appState.gainNode.connect(appState.audioContext.destination);
                                    
                                    // 更新麦克风按钮状态
                                    updateVideoMicButton();
                                    
                                    // 添加方向变化监听
                                    window.addEventListener('orientationchange', handleOrientationChange);
                                })
                                .catch(audioErr => {
                                    console.error('无法访问麦克风:', audioErr);
                                    showNotification('无法访问摄像头和麦克风，无法进行通话', 'error');
                                    // 不立即结束通话，让用户决定
                                });
                        });
                } else {
                    showNotification('浏览器不支持视频通话', 'error');
                    // 不立即结束通话，让用户知道问题
                }
            }
        }

        // 拒接来电
        function rejectCall(callType) {
            // 清除超时
            if (appState.callTimeout) {
                clearTimeout(appState.callTimeout);
                appState.callTimeout = null;
            }
            
            // 停止铃声
            stopRingtone();
            
            // 移除来电界面
            const incomingContainer = document.querySelector('.incoming-call-container');
            if (incomingContainer) {
                incomingContainer.remove();
            }
            
            // 发送拒绝通话的消息
            const responseType = callType === 'voice' ? 'voice_call_response' : 'video_call_response';
            sendServerMessage({
                type: responseType,
                data: {
                    userId: appState.currentUser.id,
                    targetUserId: appState.connectedUser.id,
                    accepted: false,
                    requestId: appState.currentCallRequestId
                }
            });
            
            // 重置通话状态
            appState.isInCall = false;
            appState.callType = null;
            
            showNotification('已拒接来电', 'info');
        }

        // 播放来电铃声
        function playRingtone() {
            // 创建音频上下文
            appState.ringtoneAudioContext = new (window.AudioContext || window.webkitAudioContext)();
            
            // 创建多个振荡器模拟铃声
            const playTone = (frequency, startTime, duration) => {
                const oscillator = appState.ringtoneAudioContext.createOscillator();
                const gainNode = appState.ringtoneAudioContext.createGain();
                
                oscillator.connect(gainNode);
                gainNode.connect(appState.ringtoneAudioContext.destination);
                
                // 设置波形类型为正弦波，更柔和
                oscillator.type = 'sine';
                oscillator.frequency.value = frequency;
                
                // 设置音量包络，让声音更自然
                gainNode.gain.setValueAtTime(0, startTime);
                gainNode.gain.linearRampToValueAtTime(0.15, startTime + 0.05);
                gainNode.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
                
                oscillator.start(startTime);
                oscillator.stop(startTime + duration);
            };
            
            // 播放更悦耳的铃声模式
            const playPattern = () => {
                const now = appState.ringtoneAudioContext.currentTime;
                
                // 创建更和谐的音序
                playTone(523.25, now, 0.3);        // C5
                playTone(659.25, now + 0.2, 0.3);    // E5
                playTone(783.99, now + 0.4, 0.3);    // G5
                playTone(659.25, now + 0.6, 0.3);    // E5
                playTone(523.25, now + 0.8, 0.4);    // C5
            };
            
            // 立即播放一次
            playPattern();
            
            // 每隔2.5秒播放一次铃声
            appState.ringtoneInterval = setInterval(playPattern, 2500);
        }

        // 停止来电铃声
        function stopRingtone() {
            if (appState.ringtoneInterval) {
                clearInterval(appState.ringtoneInterval);
                appState.ringtoneInterval = null;
            }
            
            if (appState.ringtoneOscillators) {
                appState.ringtoneOscillators.forEach(oscillator => {
                    try {
                        oscillator.stop();
                    } catch (e) {
                        // 忽略错误
                    }
                });
                appState.ringtoneOscillators = null;
            }
            
            if (appState.ringtoneAudioContext) {
                try {
                    appState.ringtoneAudioContext.close();
                } catch (e) {
                    // 忽略错误
                }
                appState.ringtoneAudioContext = null;
            }
        }

        // 播放提示音
        function playNotificationSound(type) {
            // 创建音频上下文
            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            
            // 根据类型设置不同的频率
            switch(type) {
                case 'muted':
                    oscillator.frequency.value = 300;
                    gainNode.gain.value = 0.1;
                    break;
                case 'unmuted':
                    oscillator.frequency.value = 800;
                    gainNode.gain.value = 0.1;
                    break;
                case 'speaker_on':
                    oscillator.frequency.value = 600;
                    gainNode.gain.value = 0.1;
                    break;
                case 'speaker_off':
                    oscillator.frequency.value = 400;
                    gainNode.gain.value = 0.1;
                    break;
                default:
                    oscillator.frequency.value = 500;
                    gainNode.gain.value = 0.1;
            }
            
            oscillator.start(audioContext.currentTime);
            oscillator.stop(audioContext.currentTime + 0.1);
        }
        
        // 更新语音通话UI
        function updateVoiceCallUI() {
            const timerElement = document.getElementById('voiceCallTimer');
            if (timerElement && appState.callDuration) {
                timerElement.textContent = appState.callDuration;
            }
        }

        // 视频通话
        function startVideoCall() {
            if (!appState.isConnected) {
                showNotification('请先建立连接', 'warning');
                return;
            }
            
            // 检查是否已经在通话中
            if (appState.isInCall) {
                showNotification('已经在通话中', 'warning');
                return;
            }
            
            // 发送视频通话请求
            const requestData = {
                type: 'video_call_request',
                data: {
                    userId: appState.currentUser.id,
                    displayName: appState.currentUser.displayName,
                    targetUserId: appState.connectedUser.id,
                    requestId: Date.now().toString()
                }
            };
            console.log('📹 发送视频通话请求');
            
            const success = sendServerMessage(requestData);
            
            if (!success) {
                showNotification('发送通话请求失败，请检查网络连接', 'error');
                return;
            }
            
            // 设置通话状态
            appState.isInCall = true;
            appState.callType = 'video';
            appState.isVideoMicMuted = false; // 默认麦克风开启，方便听到自己的声音
            appState.isCallInitiator = true; // 标记为通话发起方
            appState.callStartTime = Date.now();
            console.log('📞 视频通话开始');
            
            showNotification('正在发起视频通话...', 'info');
            
            // 创建等待接听界面
            createWaitingCallUI('video');
            
            // 请求摄像头和麦克风权限（预先获取，以便对方接听后立即开始）
            if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
                navigator.mediaDevices.getUserMedia({ 
                    video: { 
                        width: { ideal: 1280 },
                        height: { ideal: 720 },
                        facingMode: 'user'
                    }, 
                    audio: true
                })
                    .then(stream => {
                        appState.localStream = stream;
                        console.log('📹 摄像头和麦克风权限已获取，等待对方接听');
                        
                        // 创建音频上下文用于实时监听自己的声音
                        appState.audioContext = new (window.AudioContext || window.webkitAudioContext)();
                        appState.mediaStreamSource = appState.audioContext.createMediaStreamSource(stream);
                        appState.gainNode = appState.audioContext.createGain();
                        
                        // 创建增益节点以控制音量
                        appState.gainNode.gain.value = 0.2; // 设置较低的音量，避免回声
                        
                        // 连接音频节点
                        appState.mediaStreamSource.connect(appState.gainNode);
                        appState.gainNode.connect(appState.audioContext.destination);
                    })
                    .catch(err => {
                        console.error('无法访问摄像头或麦克风:', err);
                        // 不立即显示错误，等对方拒绝后再处理
                    });
            } else {
                showNotification('浏览器不支持视频通话', 'error');
                appState.isInCall = false;
                // 移除等待界面
                const waitingContainer = document.querySelector('.waiting-call-container');
                if (waitingContainer) {
                    waitingContainer.remove();
                }
            }
            
            // 设置超时，如果60秒内对方没有响应
            setTimeout(() => {
                if (appState && appState.isInCall && appState.isCallInitiator) {
                    console.log('⏰ 60秒超时，但通话继续');
                    showNotification('对方未响应，通话继续', 'warning');
                    // 不再调用endCall()，保持通话状态
                }
            }, 60000);
        }
        
        // 处理屏幕方向变化
        function handleOrientationChange() {
            // 重新调整视频布局
            const videoGrid = document.querySelector('.video-grid');
            if (videoGrid) {
                // 强制重新计算布局
                videoGrid.style.display = 'none';
                setTimeout(() => {
                    videoGrid.style.display = '';
                }, 10);
            }
        }
        
        // 创建视频通话界面
        let isCreatingVideoUI = false; // 防止重复创建的标志
        function createVideoCallUI() {
            console.log('🎬 创建视频通话界面');
            
            // 防止重复创建
            if (isCreatingVideoUI) {
                console.log('📹 正在创建视频界面，跳过重复调用');
                return;
            }
            
            // 检查是否已经存在视频界面
            const existingVideoContainer = document.querySelector('.video-call-container');
            if (existingVideoContainer) {
                console.log('📹 视频界面已存在，移除旧界面');
                existingVideoContainer.remove();
            }
            
            isCreatingVideoUI = true;
            const chatArea = document.querySelector('.chat-area');
            
            // 创建视频容器
            const videoContainer = document.createElement('div');
            videoContainer.className = 'video-call-container';
            videoContainer.innerHTML = `
                <div class="video-grid">
                    <div class="video-item remote-video">
                        <video id="remoteVideo" autoplay playsinline></video>
                        <div class="video-label">对方</div>
                    </div>
                    <div class="video-item local-video">
                        <video id="localVideo" autoplay muted playsinline></video>
                        <div class="video-label">我</div>
                    </div>
                </div>
                <div class="video-controls">
                    <button onclick="endCall()">
                        挂断
                    </button>
                    <button onclick="toggleVideo()" id="videoToggleBtn">
                        视频
                    </button>
                    <button id="videoMicBtn" onclick="toggleVideoMic()">
                        麦克风
                    </button>
                    <button onclick="toggleCamera()">
                        切换
                    </button>
                    <button onclick="toggleTorch()" id="torchBtn">
                        <span style="color: #666;">💡</span>
                    </button>
                </div>
            `;
            
            // 添加到聊天区域
            chatArea.appendChild(videoContainer);
            
            // 设置本地视频流
            const localVideo = document.getElementById('localVideo');
            if (localVideo && appState.localStream) {
                console.log('设置本地视频流');
                try {
                    // 使用安全的视频设置函数
                    appState.setVideoStream(localVideo, appState.localStream);
                    // 前置摄像头默认镜像显示
                    localVideo.style.transform = 'scaleX(-1)';
                } catch (error) {
                    console.error('设置本地视频流失败:', error);
                }
            } else {
                console.error('无法设置本地视频流:', localVideo ? '找到元素但无流' : '找不到元素');
            }
            
            // 检查是否支持闪光灯
            checkTorchAvailability();
            
            // 重置创建标志
            isCreatingVideoUI = false;
        }
        
        // 模拟远程视频流
        function simulateRemoteVideo() {
            const remoteVideo = document.getElementById('remoteVideo');
            if (remoteVideo && !appState.remoteVideoInterval) {
                // 创建模拟视频流
                const canvas = document.createElement('canvas');
                canvas.width = 640;
                canvas.height = 480;
                const ctx = canvas.getContext('2d');
                
                // 初始化流
                const stream = canvas.captureStream(30);
                remoteVideo.srcObject = stream;
                
                // 绘制模拟视频内容
                let frame = 0;
                
                // 使用定时器而不是requestAnimationFrame，避免卡死
                appState.remoteVideoInterval = setInterval(() => {
                    if (!appState.isInCall) {
                        clearInterval(appState.remoteVideoInterval);
                        appState.remoteVideoInterval = null;
                        return;
                    }
                    
                    try {
                        ctx.fillStyle = '#2c3e50';
                        ctx.fillRect(0, 0, canvas.width, canvas.height);
                        
                        ctx.fillStyle = '#ecf0f1';
                        ctx.font = '24px Arial';
                        ctx.textAlign = 'center';
                        ctx.fillText('模拟视频流', canvas.width / 2, canvas.height / 2);
                        
                        ctx.font = '16px Arial';
                        ctx.fillText(`帧: ${frame}`, canvas.width / 2, canvas.height / 2 + 30);
                        
                        // 添加一些动态效果
                        const time = Date.now() / 1000;
                        ctx.fillStyle = '#3498db';
                        ctx.beginPath();
                        ctx.arc(
                            canvas.width / 2 + Math.sin(time) * 100,
                            canvas.height / 2 + Math.cos(time) * 50,
                            20,
                            0,
                            2 * Math.PI
                        );
                        ctx.fill();
                        
                        frame++;
                    } catch (error) {
                        console.error('绘制视频帧时出错:', error);
                        clearInterval(appState.remoteVideoInterval);
                        appState.remoteVideoInterval = null;
                    }
                }, 1000 / 30); // 30 FPS
            }
        }
        
        // 切换视频
        function toggleVideo() {
            if (!appState.localStream) return;
            
            const videoTracks = appState.localStream.getVideoTracks();
            videoTracks.forEach(track => {
                track.enabled = !track.enabled;
            });
            
            const button = document.getElementById('videoToggleBtn');
            if (button) {
                if (videoTracks[0].enabled) {
                    button.innerHTML = '视频';
                } else {
                    button.innerHTML = '视频 <span style="color: red;">🚫</span>';
                }
            }
        }
        
        // 切换视频麦克风
        function toggleVideoMic() {
            if (!appState.localStream) return;
            
            // 确保有音频轨道
            if (appState.localStream.getAudioTracks().length === 0) {
                // 如果没有音频轨道，请求麦克风权限
                navigator.mediaDevices.getUserMedia({ audio: true })
                    .then(audioStream => {
                        const audioTrack = audioStream.getAudioTracks()[0];
                        appState.localStream.addTrack(audioTrack);
                        appState.isVideoMicMuted = false;
                        
                        // 重新创建音频上下文用于实时监听
                        if (!appState.audioContext) {
                            appState.audioContext = new (window.AudioContext || window.webkitAudioContext)();
                            appState.mediaStreamSource = appState.audioContext.createMediaStreamSource(appState.localStream);
                            appState.gainNode = appState.audioContext.createGain();
                            appState.gainNode.gain.value = 0.2;
                            appState.mediaStreamSource.connect(appState.gainNode);
                            appState.gainNode.connect(appState.audioContext.destination);
                        }
                        
                        updateVideoMicButton();
                        showNotification('麦克风已开启', 'success');
                    })
                    .catch(err => {
                        console.error('无法访问麦克风:', err);
                        showNotification('无法访问麦克风，请检查权限设置', 'error');
                    });
                return;
            }
            
            appState.isVideoMicMuted = !appState.isVideoMicMuted;
            const audioTracks = appState.localStream.getAudioTracks();
            audioTracks.forEach(track => {
                track.enabled = !appState.isVideoMicMuted;
            });
            
            // 控制音频监听
            if (appState.gainNode) {
                if (appState.isVideoMicMuted) {
                    // 静音时断开连接
                    appState.gainNode.disconnect();
                    appState.gainNode.connect(appState.audioContext.destination);
                } else {
                    // 开启时重新连接
                    appState.gainNode.disconnect();
                    appState.gainNode.connect(appState.audioContext.destination);
                }
            }
            
            updateVideoMicButton();
            
            // 播放提示音
            playNotificationSound(appState.isVideoMicMuted ? 'muted' : 'unmuted');
        }
        
        // 更新视频麦克风按钮状态
        function updateVideoMicButton() {
            const button = document.getElementById('videoMicBtn');
            if (button) {
                if (appState.isVideoMicMuted) {
                    button.innerHTML = '麦克风 <span style="color: red;">🔇</span>';
                } else {
                    button.innerHTML = '麦克风';
                }
            }
        }
        
        // 切换前后摄像头
        function toggleCamera() {
            if (!appState.localStream) return;
            
            // 检查视频轨道是否启用
            const videoTrack = appState.localStream.getVideoTracks()[0];
            const wasVideoEnabled = videoTrack ? videoTrack.enabled : true;
            
            // 停止当前视频流
            appState.localStream.getTracks().forEach(track => track.stop());
            
            // 切换摄像头
            const currentFacingMode = appState.currentFacingMode || 'user';
            const newFacingMode = currentFacingMode === 'user' ? 'environment' : 'user';
            appState.currentFacingMode = newFacingMode;
            
            // 请求新的视频流
            navigator.mediaDevices.getUserMedia({
                video: {
                    width: { ideal: 1280 },
                    height: { ideal: 720 },
                    facingMode: newFacingMode
                },
                audio: true
            })
            .then(stream => {
                appState.localStream = stream;
                
                // 如果之前视频是关闭的，保持关闭状态
                if (!wasVideoEnabled) {
                    const newVideoTrack = stream.getVideoTracks()[0];
                    if (newVideoTrack) {
                        newVideoTrack.enabled = false;
                    }
                }
                
                // 重新设置音频监听
                if (appState.audioContext) {
                    appState.mediaStreamSource.disconnect();
                    appState.mediaStreamSource = appState.audioContext.createMediaStreamSource(stream);
                    appState.mediaStreamSource.connect(appState.gainNode);
                    appState.gainNode.connect(appState.audioContext.destination);
                }
                
                // 更新视频流
                const localVideo = document.getElementById('localVideo');
                if (localVideo) {
                    try {
                        // 使用安全的视频设置函数
                        appState.setVideoStream(localVideo, stream);
                        
                        // 前置摄像头需要镜像效果
                        if (newFacingMode === 'user') {
                            localVideo.style.transform = 'scaleX(-1)';
                        } else {
                            localVideo.style.transform = 'scaleX(1)';
                        }
                    } catch (error) {
                        console.error('更新视频流失败:', error);
                    }
                }
                
                // 更新WebRTC连接中的视频轨道
                if (appState.rtcPeerConnection) {
                    // 获取发送器
                    const senders = appState.rtcPeerConnection.getSenders();
                    const videoSender = senders.find(sender => 
                        sender.track && sender.track.kind === 'video'
                    );
                    
                    // 如果找到视频发送器，替换轨道
                    if (videoSender) {
                        const newVideoTrack = stream.getVideoTracks()[0];
                        if (newVideoTrack) {
                            videoSender.replaceTrack(newVideoTrack)
                                .then(() => {
                                    console.log('摄像头切换成功，WebRTC轨道已更新');
                                })
                                .catch(err => {
                                    console.error('更新WebRTC视频轨道失败:', err);
                                });
                        }
                    }
                }
                
                // 更新按钮状态
                const flipButton = document.querySelector('.video-controls button:nth-child(4)');
                if (flipButton) {
                    if (newFacingMode === 'environment') {
                        flipButton.innerHTML = '切换 <span style="color: blue;">🔀</span>';
                    } else {
                        flipButton.innerHTML = '切换';
                    }
                }
                
                // 更新视频按钮状态
                updateVideoButtonState();
                
                showNotification(`已切换到${newFacingMode === 'user' ? '前置' : '后置'}摄像头`, 'success');
            })
            .catch(err => {
                console.error('切换摄像头失败:', err);
                showNotification('切换摄像头失败', 'error');
                
                // 重新获取原来的视频流
                navigator.mediaDevices.getUserMedia({
                    video: {
                        width: { ideal: 1280 },
                        height: { ideal: 720 },
                        facingMode: currentFacingMode
                    },
                    audio: true
                })
                .then(stream => {
                    appState.localStream = stream;
                    
                    // 保持原来的视频状态
                    if (!wasVideoEnabled) {
                        const videoTrack = stream.getVideoTracks()[0];
                        if (videoTrack) {
                            videoTrack.enabled = false;
                        }
                    }
                    
                    const localVideo = document.getElementById('localVideo');
                    if (localVideo) {
                        try {
                            appState.setVideoStream(localVideo, stream);
                            if (currentFacingMode === 'user') {
                                localVideo.style.transform = 'scaleX(-1)';
                            }
                        } catch (error) {
                            console.error('恢复视频流失败:', error);
                        }
                    }
                    
                    updateVideoButtonState();
                });
            });
        }
        
        // 更新视频按钮状态
        function updateVideoButtonState() {
            const button = document.getElementById('videoToggleBtn');
            if (button && appState.localStream) {
                const videoTrack = appState.localStream.getVideoTracks()[0];
                if (videoTrack) {
                    if (videoTrack.enabled) {
                        button.innerHTML = '视频';
                    } else {
                        button.innerHTML = '视频 <span style="color: red;">🚫</span>';
                    }
                }
            }
        }
        
        // 检查闪光灯可用性
        function checkTorchAvailability() {
            if (!appState.localStream) return;
            
            const videoTrack = appState.localStream.getVideoTracks()[0];
            if (!videoTrack) return;
            
            const capabilities = videoTrack.getCapabilities();
            if (capabilities && capabilities.torch) {
                // 闪光灯可用
                const torchBtn = document.getElementById('torchBtn');
                if (torchBtn) {
                    torchBtn.style.display = 'inline-flex';
                }
            } else {
                // 闪光灯不可用，隐藏按钮
                const torchBtn = document.getElementById('torchBtn');
                if (torchBtn) {
                    torchBtn.style.display = 'none';
                }
            }
        }
        
        // 切换闪光灯
        function toggleTorch() {
            if (!appState.localStream) return;
            
            const videoTrack = appState.localStream.getVideoTracks()[0];
            if (!videoTrack) return;
            
            const capabilities = videoTrack.getCapabilities();
            if (!capabilities || !capabilities.torch) {
                showNotification('当前设备不支持闪光灯', 'warning');
                return;
            }
            
            try {
                appState.isTorchOn = !appState.isTorchOn;
                videoTrack.applyConstraints({
                    advanced: [{ torch: appState.isTorchOn }]
                });
                
                // 更新按钮状态
                const torchBtn = document.getElementById('torchBtn');
                if (torchBtn) {
                    if (appState.isTorchOn) {
                        torchBtn.innerHTML = '<span style="color: yellow;">💡</span>';
                    } else {
                        torchBtn.innerHTML = '<span style="color: #666;">💡</span>';
                    }
                }
                
                showNotification(appState.isTorchOn ? '闪光灯已开启' : '闪光灯已关闭', 'success');
            } catch (err) {
                console.error('切换闪光灯失败:', err);
                showNotification('切换闪光灯失败', 'error');
            }
        }
        
        // 初始化WebRTC连接
        function initializeWebRTC(callType) {
            console.log('🔄 初始化WebRTC连接, 通话类型:', callType);
            
            // 如果已经存在连接，先关闭
            if (appState.rtcPeerConnection) {
                try {
                    appState.rtcPeerConnection.close();
                } catch (e) {
                    console.error('关闭现有RTC连接失败:', e);
                }
            }
            
            // 创建RTCPeerConnection，添加更多STUN服务器和TURN服务器配置
            appState.rtcPeerConnection = new RTCPeerConnection({
                iceServers: [
                    { urls: 'stun:stun.l.google.com:19302' },
                    { urls: 'stun:stun1.l.google.com:19302' },
                    { urls: 'stun:stun2.l.google.com:19302' },
                    { urls: 'stun:stun3.l.google.com:19302' },
                    { urls: 'stun:stun4.l.google.com:19302' },
                    { urls: 'stun:stun.stunprotocol.org:3478' },
                    { urls: 'stun:stun.voipbuster.com:3478' },
                    { urls: 'stun:stun.voxgratia.org:3478' }
                ],
                iceCandidatePoolSize: 10,
                iceTransportPolicy: 'all'
            });
            
            console.log('✅ RTCPeerConnection已创建');
            
            // 设置ICE连接保持机制
            appState.iceKeepAliveInterval = setInterval(() => {
                if (appState.rtcPeerConnection && appState.isInCall) {
                    const iceState = appState.rtcPeerConnection.iceConnectionState;
                    const connectionState = appState.rtcPeerConnection.connectionState;
                    
                    // 如果连接断开但不是失败，尝试重新连接
                    if (iceState === 'disconnected' && connectionState !== 'failed') {
                        console.log('🔄 ICE连接断开，尝试重新连接...');
                        // 创建新的Offer来重新建立连接
                        if (appState.isCallInitiator) {
                            appState.rtcPeerConnection.createOffer()
                                .then(offer => {
                                    return appState.rtcPeerConnection.setLocalDescription(offer);
                                })
                                .then(() => {
                                    // 发送新的Offer
                                    sendServerMessage({
                                        type: 'webrtc_offer',
                                        data: {
                                            offer: appState.rtcPeerConnection.localDescription,
                                            userId: appState.currentUser.id,
                                            targetUserId: appState.connectedUser.id
                                        }
                                    });
                                })
                                .catch(error => {
                                    console.error('重新创建Offer失败:', error);
                                });
                        }
                    }
                }
            }, 5000);
            
            // 监控连接状态 - 只记录关键断开问题
            appState.rtcPeerConnection.onconnectionstatechange = (event) => {
                try {
                    if (!appState.rtcPeerConnection || !appState.isInCall) return;
                    const state = appState.rtcPeerConnection.connectionState;
                    
                    if (state === 'connected') {
                        console.log('✅ WebRTC连接已建立');
                        if (appState.callTimeout) {
                            clearTimeout(appState.callTimeout);
                            appState.callTimeout = null;
                        }
                    } else if (state === 'failed') {
                        console.error('❌ WebRTC连接失败 - 视频可能断开');
                        showNotification('连接不稳定，但通话继续', 'warning');
                    } else if (state === 'disconnected') {
                        console.error('⚠️ WebRTC连接断开 - 视频可能断开');
                        showNotification('连接暂时断开，请检查网络', 'warning');
                    } else if (state === 'closed') {
                        console.log('📞 WebRTC连接已关闭 - 用户挂断');
                    }
                } catch (error) {
                    console.error('连接状态变化错误:', error);
                }
            };
            
            // 监控ICE连接状态 - 只记录关键断开问题
            appState.rtcPeerConnection.oniceconnectionstatechange = (event) => {
                try {
                    if (!appState.rtcPeerConnection || !appState.isInCall) return;
                    const state = appState.rtcPeerConnection.iceConnectionState;
                    
                    if (state === 'connected') {
                        console.log('✅ ICE连接已建立');
                    } else if (state === 'failed') {
                        console.error('❌ ICE连接失败 - 视频可能断开');
                        showNotification('网络连接不稳定，通话继续', 'warning');
                    } else if (state === 'disconnected') {
                        console.error('⚠️ ICE连接断开 - 视频可能断开');
                        showNotification('网络暂时断开，通话继续', 'warning');
                    } else if (state === 'closed') {
                        console.log('📞 ICE连接已关闭 - 用户挂断');
                    }
                } catch (error) {
                    console.error('ICE状态变化错误:', error);
                }
            };
            
            // 添加本地流（如果已经存在）
            if (appState.localStream) {
                appState.localStream.getTracks().forEach(track => {
                    appState.rtcPeerConnection.addTrack(track, appState.localStream);
                });
                console.log('✅ 已添加本地流到WebRTC连接');
            } else {
                console.log('⏳ 本地流尚未获取，将在权限获取后添加');
            }
            
            // 处理远程流
            appState.rtcPeerConnection.ontrack = (event) => {
                const stream = event.streams[0];
                console.log('📹 收到远程流，轨道数量:', stream.getTracks().length);
                console.log('📹 调试信息 - appState.callType:', appState.callType);
                console.log('📹 调试信息 - isCallInitiator:', appState.isCallInitiator);
                console.log('📹 调试信息 - stream.id:', stream.id);
                console.log('📹 调试信息 - stream.active:', stream.active);
                
                appState.remoteStream = stream;
                
                // 立即检查视频元素是否存在
                const remoteVideo = document.getElementById('remoteVideo');
                console.log('📹 ontrack时检查远程视频元素:', remoteVideo ? '存在' : '不存在');
                
                // 详细记录每个轨道
                stream.getTracks().forEach((track, index) => {
                    console.log(`📹 轨道 ${index}:`, {
                        kind: track.kind,
                        enabled: track.enabled,
                        muted: track.muted,
                        readyState: track.readyState,
                        id: track.id
                    });
                    
                    track.addEventListener('ended', () => {
                        if (track.kind === 'video') {
                            console.error('❌ 对方视频轨道已结束 - 视频可能断开');
                        } else {
                            console.error('❌ 对方音频轨道已结束 - 音频可能断开');
                        }
                    });
                    
                    track.addEventListener('mute', () => {
                        console.log(`🔇 远程${track.kind}轨道已静音`);
                        if (track.kind === 'video') {
                            console.error('🚨 远程视频轨道被静音，这可能导致视频无法显示！');
                            // 尝试取消静音
                            track.enabled = true;
                            console.log('📹 尝试启用远程视频轨道');
                        }
                    });
                    
                    track.addEventListener('unmute', () => {
                        console.log(`🔊 远程${track.kind}轨道取消静音`);
                    });
                });
                
                // 使用全局的callType而不是局部变量
                if (appState.callType === 'video') {
                    console.log('📹 视频通话，尝试设置远程视频流');
                    const remoteVideo = document.getElementById('remoteVideo');
                    console.log('📹 远程视频元素:', remoteVideo);
                    
                    if (remoteVideo) {
                        console.log('📹 调用setVideoStream设置远程流');
                        appState.setVideoStream(remoteVideo, appState.remoteStream);
                        console.log('✅ 远程视频流设置成功');
                        
                        // 额外检查视频元素状态
                        setTimeout(() => {
                            console.log('📹 视频元素状态检查:', {
                                srcObject: remoteVideo.srcObject,
                                videoWidth: remoteVideo.videoWidth,
                                videoHeight: remoteVideo.videoHeight,
                                readyState: remoteVideo.readyState,
                                paused: remoteVideo.paused
                            });
                        }, 1000);
                    } else {
                        console.error('❌ 找不到远程视频元素');
                        console.log('📹 当前DOM中的video元素:', document.querySelectorAll('video'));
                    }
                } else {
                    console.log('✅ 语音通话已连接');
                }
            };
            
            // 处理ICE候选
            appState.rtcPeerConnection.onicecandidate = (event) => {
                if (event.candidate) {
                    // 发送ICE候选给对方
                    sendServerMessage({
                        type: 'webrtc_ice_candidate',
                        data: {
                            userId: appState.currentUser.id,
                            targetUserId: appState.connectedUser.id,
                            candidate: event.candidate
                        }
                    });
                } else {
                    console.log('✅ ICE候选收集完成');
                }
            };
            
            // 如果是通话发起方，等待视频界面创建完成后再创建Offer
            if (appState.isCallInitiator) {
                // 等待视频界面创建完成
                const waitForVideoElements = () => {
                    const remoteVideo = document.getElementById('remoteVideo');
                    const localVideo = document.getElementById('localVideo');
                    
                    if (remoteVideo && localVideo) {
                        console.log('🔄 视频元素已准备好，创建WebRTC Offer');
                        appState.rtcPeerConnection.createOffer()
                            .then(offer => {
                                console.log('✅ Offer已创建');
                                return appState.rtcPeerConnection.setLocalDescription(offer);
                            })
                            .then(() => {
                                console.log('📤 发送Offer给对方');
                                // 发送Offer给对方
                                sendServerMessage({
                                    type: 'webrtc_offer',
                                    data: {
                                        userId: appState.currentUser.id,
                                        targetUserId: appState.connectedUser.id,
                                        offer: appState.rtcPeerConnection.localDescription
                                    }
                                });
                            })
                            .catch(error => {
                                console.error('❌ 创建Offer失败 - 视频可能断开:', error);
                                showNotification('建立通话连接失败，但通话继续', 'warning');
                            });
                    } else {
                        // 如果视频元素还没准备好，继续等待
                        console.log('⏳ 等待视频元素创建...');
                        setTimeout(waitForVideoElements, 50);
                    }
                };
                
                // 开始等待
                setTimeout(waitForVideoElements, 100);
            }
        }

        // 处理WebRTC Offer
        function handleWebRTCOffer(offer) {
            console.log('📥 收到WebRTC Offer');
            if (!appState.rtcPeerConnection) {
                console.log('🔄 RTC连接未初始化，正在初始化...');
                initializeWebRTC(appState.callType);
                
                // 等待连接初始化完成后再处理Offer
                setTimeout(() => {
                    processOffer(offer);
                }, 100);
            } else {
                processOffer(offer);
            }
        }
        
        // 处理Offer的内部函数
        function processOffer(offer) {
            
            // 等待一小段时间确保ICE候选收集已经开始
            setTimeout(() => {
                if (!appState.rtcPeerConnection) {
                    console.error('❌ RTC连接未初始化，无法处理Offer - 视频可能断开');
                    return;
                }
                
                console.log('🔗 设置远程描述');
                appState.rtcPeerConnection.setRemoteDescription(new RTCSessionDescription(offer))
                    .then(() => {
                        console.log('✅ 远程描述已设置，创建Answer');
                        
                        // 处理暂存的ICE候选
                        if (appState.pendingIceCandidates && appState.pendingIceCandidates.length > 0) {
                            console.log('➕ 添加暂存的ICE候选');
                            appState.pendingIceCandidates.forEach(candidate => {
                                appState.rtcPeerConnection.addIceCandidate(new RTCIceCandidate(candidate))
                                    .catch(err => {
                                        console.error('❌ 添加暂存ICE候选失败 - 视频可能断开:', err);
                                    });
                            });
                            appState.pendingIceCandidates = [];
                        }
                        
                        // 等待本地流准备就绪
                        const waitForLocalStream = () => {
                            return new Promise((resolve, reject) => {
                                const checkStream = () => {
                                    if (appState.localStream) {
                                        console.log('📹 本地流已准备好，创建Answer');
                                        appState.rtcPeerConnection.createAnswer()
                                            .then(answer => {
                                                console.log('✅ Answer已创建');
                                                return appState.rtcPeerConnection.setLocalDescription(answer);
                                            })
                                            .then(() => {
                                                console.log('📤 发送Answer给对方');
                                                sendServerMessage({
                                                    type: 'webrtc_answer',
                                                    data: {
                                                        userId: appState.currentUser.id,
                                                        targetUserId: appState.connectedUser.id,
                                                        answer: appState.rtcPeerConnection.localDescription
                                                    }
                                                });
                                                resolve();
                                            })
                                            .catch(reject);
                                    } else {
                                        console.log('⏳ 等待本地流...');
                                        setTimeout(checkStream, 100);
                                    }
                                };
                                checkStream();
                            });
                        };
                        
                        // 开始等待本地流
                        return waitForLocalStream();
                    })
                    .catch(error => {
                        console.error('❌ 处理Offer失败 - 视频可能断开:', error);
                        showNotification('建立通话连接失败，但通话继续', 'warning');
                    });
            }, 300);
        }

        // 处理WebRTC Answer

                function handleWebRTCAnswer(answer) {
                            console.log('📥 收到WebRTC Answer');
                
                            if (!appState.rtcPeerConnection) {
                                console.error('❌ RTC连接未初始化 - 视频可能断开');
                                return;
                            }
                            
                            if (!answer) {
                                console.error('❌ Answer为空，无法设置远程描述 - 视频可能断开');
                                return;
                            }
                            
                            console.log('🔗 设置远程描述');
                            console.log('📹 发起方当前视频元素检查:');
                            console.log('  - remoteVideo:', document.getElementById('remoteVideo'));
                            console.log('  - localVideo:', document.getElementById('localVideo'));
                            
                            appState.rtcPeerConnection.setRemoteDescription(new RTCSessionDescription(answer))
                                .then(() => {
                                    console.log('✅ 远程描述设置成功');
                                    
                                    // 处理暂存的ICE候选
                                    if (appState.pendingIceCandidates && appState.pendingIceCandidates.length > 0) {
                                        console.log('➕ 添加暂存的ICE候选');
                                        appState.pendingIceCandidates.forEach(candidate => {
                                            appState.rtcPeerConnection.addIceCandidate(new RTCIceCandidate(candidate))
                                                .catch(err => {
                                                    console.error('❌ 添加暂存ICE候选失败 - 视频可能断开:', err);
                                                });
                                        });
                                        appState.pendingIceCandidates = [];
                                    }
                                })
                                .catch(error => {
                                    console.error('❌ 处理Answer失败 - 视频可能断开:', error);
                                    showNotification('建立通话连接失败，但通话继续', 'warning');
                                });
                        }
        // 处理WebRTC ICE Candidate
        function handleWebRTCIceCandidate(candidate) {
            if (!appState.rtcPeerConnection) {
                console.error('❌ RTC连接未初始化 - 视频可能断开');
                return;
            }
            
            if (!candidate) {
                console.error('❌ ICE候选为空 - 视频可能断开');
                return;
            }
            
            // 检查远程描述是否已设置
            if (!appState.rtcPeerConnection.remoteDescription) {
                // 如果远程描述未设置，暂存ICE候选
                if (!appState.pendingIceCandidates) {
                    appState.pendingIceCandidates = [];
                }
                appState.pendingIceCandidates.push(candidate);
                return;
            }
            
            appState.rtcPeerConnection.addIceCandidate(new RTCIceCandidate(candidate))
                .catch(error => {
                    console.error('❌ 添加ICE候选失败 - 视频可能断开:', error);
                });
        }

        // 结束通话 - 只有用户主动点击挂断按钮时才能调用
        function endCall() {
            if (!appState.isInCall) {
                return;
            }
            
            const elapsed = appState.callStartTime ? Date.now() - appState.callStartTime : 0;
            console.log(`📞 用户主动结束通话 - 通话时长: ${Math.floor(elapsed/1000)}秒`);
            console.trace('endCall调用栈');
            
            // 在重置callType之前先保存它
            const callType = appState.callType;
            
            // 发送通话结束消息给对方
            if (appState.connectedUser) {
                sendServerMessage({
                    type: 'call_ended',
                    data: {
                        userId: appState.currentUser.id,
                        targetUserId: appState.connectedUser.id
                    }
                });
            }
            
            // 标记通话状态为已结束
            appState.isInCall = false;
            appState.callType = null;
            appState.isMuted = false;
            appState.isVideoMicMuted = false;
            appState.isSpeakerOn = false;
            appState.isCallInitiator = false;
            
            // 清理通话计时器
            if (appState.callTimer) {
                clearInterval(appState.callTimer);
                appState.callTimer = null;
            }
            
            // 清理超时
            if (appState.callTimeout) {
                clearTimeout(appState.callTimeout);
                appState.callTimeout = null;
            }
            
            // 清理断开检测超时
            if (appState.disconnectTimeout) {
                clearTimeout(appState.disconnectTimeout);
                appState.disconnectTimeout = null;
            }
            
            // 清理ICE保持连接定时器
            if (appState.iceKeepAliveInterval) {
                clearInterval(appState.iceKeepAliveInterval);
                appState.iceKeepAliveInterval = null;
            }
            
            // 清理远程视频模拟
            if (appState.remoteVideoInterval) {
                clearInterval(appState.remoteVideoInterval);
                appState.remoteVideoInterval = null;
            }
            
            // 清理音频上下文
            if (appState.audioContext) {
                try {
                    appState.audioContext.close();
                } catch (e) {
                    console.error('关闭音频上下文失败:', e);
                }
                appState.audioContext = null;
            }
            
            // 停止录音（但不保存）
            if (appState.mediaRecorder && appState.mediaRecorder.state !== 'inactive') {
                appState.mediaRecorder.stop();
                appState.mediaRecorder = null;
            }
            appState.audioChunks = [];
            
            // 移除方向变化监听
            window.removeEventListener('orientationchange', handleOrientationChange);
            
            // 关闭WebRTC连接
            if (appState.rtcPeerConnection) {
                try {
                    // 先清除事件监听器，防止在关闭过程中触发事件
                    appState.rtcPeerConnection.onconnectionstatechange = null;
                    appState.rtcPeerConnection.oniceconnectionstatechange = null;
                    appState.rtcPeerConnection.onicecandidate = null;
                    appState.rtcPeerConnection.ontrack = null;
                    
                    // 关闭连接
                    appState.rtcPeerConnection.close();
                } catch (error) {
                    console.error('关闭WebRTC连接时出错:', error);
                } finally {
                    appState.rtcPeerConnection = null;
                }
            }
            
            // 关闭本地音频流
            if (appState.localStream) {
                appState.localStream.getTracks().forEach(track => {
                    try {
                        track.stop();
                    } catch (e) {
                        console.error('停止媒体轨道失败:', e);
                    }
                });
                appState.localStream = null;
            }
            
            // 关闭远程音频流
            if (appState.remoteStream) {
                appState.remoteStream.getTracks().forEach(track => {
                    try {
                        track.stop();
                    } catch (e) {
                        console.error('停止远程媒体轨道失败:', e);
                    }
                });
                appState.remoteStream = null;
            }
            
            // 移除各种通话界面
            const videoContainer = document.querySelector('.video-call-container');
            if (videoContainer) {
                videoContainer.remove();
            }
            
            const voiceContainer = document.querySelector('.voice-call-container');
            if (voiceContainer) {
                voiceContainer.remove();
            }
            
            const waitingContainer = document.querySelector('.waiting-call-container');
            if (waitingContainer) {
                waitingContainer.remove();
            }
            
            const incomingContainer = document.querySelector('.incoming-call-container');
            if (incomingContainer) {
                incomingContainer.remove();
            }
            
            // 停止铃声
            stopRingtone();
            
            // 更新UI
            updateCallUI();
            showNotification('通话已结束', 'info');
            
            // 添加通话结束消息
            if (appState.isConnected) {
                const callIcon = callType === 'video' ? '📹' : '📞';
                console.log('📞 通话结束，类型:', callType, '图标:', callIcon);
                
                const message = {
                    id: Date.now(),
                    text: `${callIcon} 通话已结束 (时长: ${appState.callDuration || '0:00'})`,
                    sender: 'system',
                    timestamp: new Date(),
                    type: 'system'
                };
                appState.messageHistory.push(message);
                displayMessage(message, 'sent');
            }
        }
        
        // 开始录音
        function startRecording() {
            if (!appState.localStream) return;
            
            // 使用MediaRecorder API录制音频
            appState.mediaRecorder = new MediaRecorder(appState.localStream);
            
            appState.audioChunks = [];
            
            appState.mediaRecorder.ondataavailable = (event) => {
                appState.audioChunks.push(event.data);
            };
            
            appState.mediaRecorder.start();
        }
        
        // 停止录音
        function stopRecording() {
            if (!appState.mediaRecorder) return;
            
            appState.mediaRecorder.stop();
            
            // 创建音频Blob
            const audioBlob = new Blob(appState.audioChunks, { type: 'audio/webm' });
            
            // 创建音频URL（但不发送消息）
            appState.audioUrl = URL.createObjectURL(audioBlob);
            appState.audioBlob = audioBlob;
        }
        
        // 播放音频
        function playAudio(audioUrl, element) {
            const audio = new Audio(audioUrl);
            audio.play();
            
            audio.addEventListener('loadedmetadata', () => {
                // 更新音频时长显示
                const duration = Math.floor(audio.duration);
                const minutes = Math.floor(duration / 60);
                const seconds = Math.floor(duration % 60);
                const timeStr = `${minutes}:${seconds.toString().padStart(2, '0')}`;
                
                // 更新时间显示
                const timeElement = element.querySelector('.audio-duration');
                if (timeElement) {
                    timeElement.textContent = timeStr;
                }
            });
            
            audio.addEventListener('ended', () => {
                // 音频播放结束后的处理
                if (element) {
                    element.classList.add('audio-ended');
                }
            });
        }
        
        // 显示音频消息
        function displayAudioMessage(message, direction) {
            const container = document.getElementById('messagesContainer');
            
            // 移除空状态
            const emptyState = container.querySelector('.empty-state');
            if (emptyState) {
                emptyState.remove();
            }
            
            // 创建消息元素
            const messageElement = document.createElement('div');
            messageElement.className = `message ${direction}`;
            
            const contentElement = document.createElement('div');
            contentElement.className = 'message-content';
            
            // 创建自定义音频播放器控件
            const audioPlayerContainer = document.createElement('div');
            audioPlayerContainer.className = 'audio-player-container';
            audioPlayerContainer.style.cssText = 'display: flex; align-items: center; gap: 10px; background: rgba(0,0,0,0.1); padding: 10px; border-radius: 8px; margin-top: 8px;';
            
            // 播放/暂停按钮
            const playButton = document.createElement('button');
            playButton.innerHTML = '▶️';
            playButton.style.cssText = 'background: none; border: none; font-size: 20px; cursor: pointer; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;';
            
            // 进度条
            const progressBar = document.createElement('div');
            progressBar.style.cssText = 'flex: 1; height: 4px; background: rgba(255,255,255,0.3); border-radius: 2px; position: relative;';
            
            const progressFill = document.createElement('div');
            progressFill.style.cssText = 'height: 100%; background: var(--accent-color); border-radius: 2px; width: 0%; transition: width 0.1s;';
            progressBar.appendChild(progressFill);
            
            // 时间显示
            const timeDisplay = document.createElement('span');
            timeDisplay.textContent = '0:00';
            timeDisplay.style.cssText = 'font-size: 12px; color: var(--text-secondary); min-width: 40px;';
            
            // 音量控制
            const volumeControl = document.createElement('div');
            volumeControl.style.cssText = 'display: flex; align-items: center; gap: 5px;';
            
            const volumeIcon = document.createElement('span');
            volumeIcon.textContent = '🔊';
            volumeIcon.style.cssText = 'font-size: 16px; cursor: pointer;';
            
            const volumeSlider = document.createElement('input');
            volumeSlider.type = 'range';
            volumeSlider.min = '0';
            volumeSlider.max = '100';
            volumeSlider.value = '50';
            volumeSlider.style.cssText = 'width: 60px; height: 4px;';
            
            volumeControl.appendChild(volumeIcon);
            volumeControl.appendChild(volumeSlider);
            
            audioPlayerContainer.appendChild(playButton);
            audioPlayerContainer.appendChild(progressBar);
            audioPlayerContainer.appendChild(timeDisplay);
            audioPlayerContainer.appendChild(volumeControl);
            
            // 创建实际的音频元素（隐藏）
            const audioPlayer = document.createElement('audio');
            audioPlayer.src = message.content;
            audioPlayer.preload = 'metadata';
            
            const infoElement = document.createElement('div');
            infoElement.className = 'file-info';
            infoElement.innerHTML = `
                <div class="file-name">🎤 ${message.text}</div>
                <div class="audio-duration">加载中...</div>
            `;
            
            const timeElement = document.createElement('div');
            timeElement.className = 'message-time';
            timeElement.textContent = formatTime(message.timestamp);
            
            contentElement.appendChild(audioPlayerContainer);
            contentElement.appendChild(infoElement);
            contentElement.appendChild(timeElement);
            messageElement.appendChild(contentElement);
            
            container.appendChild(messageElement);
            
            // 播放控制
            let isPlaying = false;
            
            playButton.addEventListener('click', () => {
                if (isPlaying) {
                    audioPlayer.pause();
                    playButton.innerHTML = '▶️';
                } else {
                    audioPlayer.play();
                    playButton.innerHTML = '⏸️';
                }
                isPlaying = !isPlaying;
            });
            
            // 音量控制
            volumeSlider.addEventListener('input', () => {
                audioPlayer.volume = volumeSlider.value / 100;
                if (volumeSlider.value == 0) {
                    volumeIcon.textContent = '🔇';
                } else if (volumeSlider.value < 50) {
                    volumeIcon.textContent = '🔉';
                } else {
                    volumeIcon.textContent = '🔊';
                }
            });
            
            // 音频时间更新
            audioPlayer.addEventListener('timeupdate', () => {
                const current = audioPlayer.currentTime;
                const duration = audioPlayer.duration;
                
                if (!isNaN(duration)) {
                    const progressPercent = (current / duration) * 100;
                    progressFill.style.width = progressPercent + '%';
                    
                    const currentMinutes = Math.floor(current / 60);
                    const currentSeconds = Math.floor(current % 60);
                    timeDisplay.textContent = `${currentMinutes}:${currentSeconds.toString().padStart(2, '0')}`;
                }
            });
            
            // 音频元数据加载完成
            audioPlayer.addEventListener('loadedmetadata', () => {
                const duration = Math.floor(audioPlayer.duration);
                const minutes = Math.floor(duration / 60);
                const seconds = Math.floor(duration % 60);
                const timeStr = `${minutes}:${seconds.toString().padStart(2, '0')}`;
                
                const durationElement = infoElement.querySelector('.audio-duration');
                if (durationElement) {
                    durationElement.textContent = `时长: ${timeStr}`;
                }
                
                // 音频元数据加载完成后滚动到底部
                setTimeout(() => {
                    container.scrollTop = container.scrollHeight;
                }, 100);
            });
            
            // 音频播放结束
            audioPlayer.addEventListener('ended', () => {
                isPlaying = false;
                playButton.innerHTML = '▶️';
                progressFill.style.width = '0%';
                timeDisplay.textContent = '0:00';
            });
            
            // 如果是发送的消息，自动播放一次（让用户听到自己的声音）
            if (direction === 'sent') {
                audioPlayer.addEventListener('canplaythrough', () => {
                    audioPlayer.play().then(() => {
                        playButton.innerHTML = '⏸️';
                        isPlaying = true;
                    }).catch(err => {
                        console.log('自动播放失败:', err);
                    });
                }, { once: true });
            }
        }
        
        // 开始通话计时
        function startCallTimer() {
            appState.callStartTime = Date.now();
            appState.callDuration = '0:00';
            
            appState.callTimer = setInterval(() => {
                const elapsed = Date.now() - appState.callStartTime;
                const minutes = Math.floor(elapsed / 60000);
                const seconds = Math.floor((elapsed % 60000) / 1000);
                appState.callDuration = `${minutes}:${seconds.toString().padStart(2, '0')}`;
                updateCallUI();
                
                // 每30秒检查一次连接状态
                if (seconds % 30 === 0) {
                    checkConnectionHealth();
                }
            }, 1000);
        }
        
        // 检查连接健康状态 - 仅记录关键断开问题
        function checkConnectionHealth() {
            if (!appState.rtcPeerConnection || !appState.isInCall) {
                return;
            }
            
            const connectionState = appState.rtcPeerConnection.connectionState;
            const iceState = appState.rtcPeerConnection.iceConnectionState;
            
            // 只在状态异常时记录
            if (connectionState !== 'connected' && connectionState !== 'connecting') {
                console.error('⚠️ 连接健康检查 - 连接状态异常:', connectionState, 'ICE状态:', iceState);
                
                // 如果连接失败，尝试重新创建Offer（仅发起方）
                if (connectionState === 'failed' && appState.isCallInitiator) {
                    console.log('🔄 尝试重新连接...');
                    recreateConnection();
                }
            }
            
            // 检查视频元素状态
            const remoteVideo = document.getElementById('remoteVideo');
            const localVideo = document.getElementById('localVideo');
            
            if (remoteVideo) {
                console.log('📹 健康检查 - 远程视频:', {
                    srcObject: !!remoteVideo.srcObject,
                    videoWidth: remoteVideo.videoWidth,
                    videoHeight: remoteVideo.videoHeight,
                    readyState: remoteVideo.readyState,
                    paused: remoteVideo.paused
                });
                
                // 如果远程视频没有流，尝试重新设置
                if (!remoteVideo.srcObject && appState.remoteStream) {
                    console.warn('⚠️ 远程视频元素没有流，尝试重新设置');
                    appState.setVideoStream(remoteVideo, appState.remoteStream);
                }
            }
            
            if (localVideo) {
                console.log('📹 健康检查 - 本地视频:', {
                    srcObject: !!localVideo.srcObject,
                    videoWidth: localVideo.videoWidth,
                    videoHeight: localVideo.videoHeight,
                    readyState: localVideo.readyState,
                    paused: localVideo.paused
                });
                
                // 如果本地视频没有流，尝试重新设置
                if (!localVideo.srcObject && appState.localStream) {
                    console.warn('⚠️ 本地视频元素没有流，尝试重新设置');
                    appState.setVideoStream(localVideo, appState.localStream);
                }
            }
            
            // 检查远程流是否仍然活跃
            if (appState.remoteStream) {
                const videoTracks = appState.remoteStream.getVideoTracks();
                const audioTracks = appState.remoteStream.getAudioTracks();
                
                if (videoTracks.length > 0) {
                    if (!videoTracks[0].enabled) {
                        console.error('⚠️ 检测到远程视频轨道已禁用，尝试启用');
                        videoTracks[0].enabled = true;
                    }
                    if (videoTracks[0].muted) {
                        console.warn('⚠️ 远程视频轨道被静音');
                    }
                }
                
                if (audioTracks.length > 0 && !audioTracks[0].enabled) {
                    console.error('⚠️ 检测到远程音频轨道已禁用，尝试启用');
                    audioTracks[0].enabled = true;
                }
            }
        }
        
        // 重新创建连接
        function recreateConnection() {
            if (!appState.isCallInitiator || !appState.rtcPeerConnection) {
                return;
            }
            
            console.log('🔄 重新创建WebRTC连接');
            
            // 保存旧的连接状态
            const oldConnection = appState.rtcPeerConnection;
            
            // 创建新连接
            initializeWebRTC('video');
            
            // 等待新连接初始化完成后重新添加本地流
            setTimeout(() => {
                if (appState.localStream && appState.rtcPeerConnection) {
                    appState.localStream.getTracks().forEach(track => {
                        appState.rtcPeerConnection.addTrack(track, appState.localStream);
                    });
                    
                    // 创建新的Offer
                    appState.rtcPeerConnection.createOffer()
                        .then(offer => {
                            return appState.rtcPeerConnection.setLocalDescription(offer);
                        })
                        .then(() => {
                            sendServerMessage({
                                type: 'webrtc_offer',
                                data: {
                                    userId: appState.currentUser.id,
                                    targetUserId: appState.connectedUser.id,
                                    offer: appState.rtcPeerConnection.localDescription
                                }
                            });
                        })
                        .catch(error => {
                            console.error('重新连接失败:', error);
                        });
                }
            }, 500);
            
            // 关闭旧连接
            try {
                oldConnection.close();
            } catch (e) {
                console.error('关闭旧连接失败:', e);
            }
        }
        
        // 更新通话UI
        function updateCallUI() {
            if (appState.callType === 'voice') {
                updateVoiceCallUI();
            } else if (appState.callType === 'video') {
                // 视频通话UI更新可以在这里添加
            }
        }

        // 更新连接状态显示
        function updateConnectionStatus(status) {
            // 在手机端，从设置面板获取元素
            const statusDot = window.innerWidth <= 768 
                ? document.querySelector('.settings-panel #statusDot')
                : document.getElementById('statusDot');
            const statusText = window.innerWidth <= 768 
                ? document.querySelector('.settings-panel #statusText')
                : document.getElementById('statusText');
            
            if (!statusDot || !statusText) return;
            
            // 清除所有状态类
            statusDot.classList.remove('online', 'connecting');
            
            if (status === true) {
                // 已连接
                statusDot.classList.add('online');
                statusText.textContent = '已连接';
            } else if (status === 'connecting') {
                // 正在连接
                statusDot.classList.add('connecting');
                statusText.textContent = '正在连接';
            } else {
                // 未连接
                statusText.textContent = '等待连接';
            }
        }

        // 显示通知
        function showNotification(message, type = 'info') {
            const notification = document.createElement('div');
            notification.className = 'notification';
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                if (notification.parentNode) {
                    notification.parentNode.removeChild(notification);
                }
            }, 3000);
        }

        // 格式化时间
        function formatTime(date) {
            return date.toLocaleTimeString('zh-CN', { 
                hour: '2-digit', 
                minute: '2-digit' 
            });
        }

        // 格式化文件大小
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // 键盘事件处理
        function handleTargetKeyPress(event) {
            if (event.key === 'Enter') {
                establishConnection();
            }
        }
        
        // 确保设置面板中的输入框也能响应回车键
        document.addEventListener('DOMContentLoaded', function() {
            // 初始化文件拖拽功能
            initFileDropZone();
            
            // 为设置面板中的输入框添加事件监听
            setTimeout(() => {
                const settingsInput = document.querySelector('.settings-panel #targetIdInput');
                if (settingsInput) {
                    settingsInput.addEventListener('keypress', function(event) {
                        if (event.key === 'Enter') {
                            establishConnection();
                        }
                    });
                }
            }, 100);
        });

        // 自动调整textarea高度
        function autoResizeTextarea() {
            const textarea = document.getElementById('messageInput');
            textarea.style.height = 'auto';
            textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';
        }

        function handleMessageKeyPress(event) {
            // 检查是否按下了Ctrl+Enter
            if (event.key === 'Enter' && event.ctrlKey) {
                // Ctrl+Enter 发送消息
                event.preventDefault();
                dispatchMessage();
                return;
            }
            
            // 如果只是Enter键，允许换行
            if (event.key === 'Enter') {
                setTimeout(autoResizeTextarea, 0);
            }
        }

        // 防止双击缩放
        let lastTouchEnd = 0;
        document.addEventListener('touchend', function (event) {
            const now = (new Date()).getTime();
            if (now - lastTouchEnd <= 300) {
                event.preventDefault();
            }
            lastTouchEnd = now;
        }, false);

        // 打开设置面板
        function openSettingsPanel() {
            const panel = document.getElementById('settingsPanel');
            const overlay = document.getElementById('settingsOverlay');
            panel.classList.add('open');
            overlay.classList.add('open');
            
            // 显示左滑提示
            setTimeout(() => {
                const hint = document.getElementById('swipeHint');
                hint.style.opacity = '1';
                setTimeout(() => {
                    hint.style.opacity = '0';
                }, 2000);
            }, 1000);
        }

        // 关闭设置面板
        function closeSettingsPanel() {
            const panel = document.getElementById('settingsPanel');
            const overlay = document.getElementById('settingsOverlay');
            panel.classList.remove('open');
            overlay.classList.remove('open');
        }

        // 触摸滑动处理
        let touchStartX = 0;
        let touchEndX = 0;
        let touchStartY = 0;
        let isSwiping = false;
        
        document.addEventListener('touchstart', function(e) {
            touchStartX = e.changedTouches[0].screenX;
            touchStartY = e.changedTouches[0].screenY;
            isSwiping = false;
        }, false);
        
        document.addEventListener('touchmove', function(e) {
            const touchX = e.changedTouches[0].screenX;
            const touchY = e.changedTouches[0].screenY;
            const deltaX = Math.abs(touchX - touchStartX);
            const deltaY = Math.abs(touchY - touchStartY);
            
            // 判断是否为水平滑动
            if (deltaX > deltaY && deltaX > 10) {
                isSwiping = true;
            }
        }, false);
        
        document.addEventListener('touchend', function(e) {
            touchEndX = e.changedTouches[0].screenX;
            if (isSwiping) {
                handleSwipe();
            }
        }, false);
        
        function handleSwipe() {
            const panel = document.getElementById('settingsPanel');
            const isOpen = panel.classList.contains('open');
            const swipeDistance = touchEndX - touchStartX;
            const swipeThreshold = 50; // 滑动阈值
            
            // 左滑打开设置面板
            if (!isOpen && swipeDistance < -swipeThreshold) {
                openSettingsPanel();
            }
            // 右滑关闭设置面板
            else if (isOpen && swipeDistance > swipeThreshold) {
                closeSettingsPanel();
            }
        }

        // 初始化应用
        window.addEventListener('DOMContentLoaded', () => {
            generateUserId();
            loadThemePreference();
            loadChatHistory();
            
            // 初始化WebSocket连接
            connectWebSocket();
            
            // 初始化在线用户和语音录制功能
            initializeOnlineUsers();
            
            // 初始化撤销反撤销功能
            const messageInput = document.getElementById('messageInput');
            currentInputContent = messageInput.value;
            updateUndoRedoButtonStates();
            
            // 添加输入事件监听器
            messageInput.addEventListener('input', autoResizeTextarea);
            
            // 添加输入内容变化监听，用于保存撤销状态
            messageInput.addEventListener('input', saveInputState);
            
            // 添加全局键盘事件监听，确保Ctrl+Enter始终可用
            document.addEventListener('keydown', function(event) {
                // 检查是否按下了Ctrl+Enter
                if (event.key === 'Enter' && event.ctrlKey) {
                    // 检查是否有已连接的聊天
                    if (appState.isConnected) {
                        // 阻止默认行为
                        event.preventDefault();
                        // 发送消息
                        dispatchMessage();
                    }
                }
                
                // Ctrl+Z 撤销
                if (event.ctrlKey && event.key === 'z' && !event.shiftKey) {
                    const messageInput = document.getElementById('messageInput');
                    // 如果输入框有焦点，执行撤销操作
                    if (document.activeElement === messageInput) {
                        event.preventDefault();
                        undoInput();
                    }
                }
                
                // Ctrl+Shift+Z 或 Ctrl+Y 反撤销
                if ((event.ctrlKey && event.shiftKey && event.key === 'Z') || (event.ctrlKey && event.key === 'y')) {
                    const messageInput = document.getElementById('messageInput');
                    // 如果输入框有焦点，执行反撤销操作
                    if (document.activeElement === messageInput) {
                        event.preventDefault();
                        redoInput();
                    }
                }
            });
            
            // 防止iOS输入框缩放
            document.addEventListener('gesturestart', function (e) {
                e.preventDefault();
            });
            
            // 只在手机端显示左滑提示
            if (window.innerWidth <= 768) {
                setTimeout(() => {
                    const hint = document.getElementById('swipeHint');
                    hint.style.opacity = '1';
                    setTimeout(() => {
                        hint.style.opacity = '0';
                    }, 3000);
                }, 2000);
                
                // 延迟更新手机端的列表，确保设置面板已经加载
                setTimeout(() => {
                    updateOnlineUsersList();
                    updateUsersList();
                }, 100);
            }
            
            // 页面卸载时关闭WebSocket连接
            window.addEventListener('beforeunload', () => {
                if (appState.websocket) {
                    // 发送用户下线消息
                    if (appState.isServerConnected && appState.currentUser) {
                        sendServerMessage({
                            type: 'user_offline',
                            data: {
                                userId: appState.currentUser.id
                            }
                        });
                    }
                    
                    // 关闭WebSocket连接
                    appState.websocket.close();
                }
            });
            
            console.log('✅ 清新聊天室已初始化');
        });

        // 初始化在线用户
        function initializeOnlineUsers() {
            // 初始化在线用户列表为空，等待服务器推送真实用户
            appState.onlineUsers = [];
            updateOnlineUsersList();
            
            // 初始化语音录制按钮事件
            initializeVoiceRecording();
        }

        // 初始化语音录制功能
        function initializeVoiceRecording() {
            const voiceRecordBtn = document.getElementById('voiceRecordBtn');
            if (!voiceRecordBtn) return;
            
            // 添加脉冲效果
            voiceRecordBtn.classList.add('pulse');
            
            // 鼠标事件
            voiceRecordBtn.addEventListener('mousedown', startVoiceRecording);
            voiceRecordBtn.addEventListener('mouseup', stopVoiceRecording);
            voiceRecordBtn.addEventListener('mouseleave', stopVoiceRecording);
            
            // 触摸事件
            voiceRecordBtn.addEventListener('touchstart', (e) => {
                e.preventDefault();
                startVoiceRecording();
            });
            voiceRecordBtn.addEventListener('touchend', (e) => {
                e.preventDefault();
                stopVoiceRecording();
            });
            voiceRecordBtn.addEventListener('touchcancel', (e) => {
                e.preventDefault();
                stopVoiceRecording();
            });
        }

        // 开始语音录制
        async function startVoiceRecording() {
            if (appState.isRecording) return;
            
            try {
                // 请求麦克风权限
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                
                // 创建MediaRecorder实例
                appState.voiceMediaRecorder = new MediaRecorder(stream);
                appState.voiceAudioChunks = [];
                
                // 设置录制数据可用事件
                appState.voiceMediaRecorder.ondataavailable = (event) => {
                    if (event.data.size > 0) {
                        appState.voiceAudioChunks.push(event.data);
                    }
                };
                
                // 设置录制停止事件
                appState.voiceMediaRecorder.onstop = () => {
                    // 创建音频Blob
                    const audioBlob = new Blob(appState.voiceAudioChunks, { type: 'audio/webm' });
                    const audioUrl = URL.createObjectURL(audioBlob);
                    
                    // 计算录制时长
                    const duration = appState.recordingStartTime ? 
                        Math.floor((Date.now() - appState.recordingStartTime) / 1000) : 0;
                    
                    // 发送语音消息
                    sendVoiceMessage(audioUrl, duration);
                    
                    // 停止所有音轨
                    stream.getTracks().forEach(track => track.stop());
                };
                
                // 开始录制
                appState.voiceMediaRecorder.start();
                appState.isRecording = true;
                appState.recordingStartTime = Date.now();
                
                // 更新UI
                updateRecordingUI(true);
                
                // 开始录音计时
                startRecordingTimer();
                
            } catch (error) {
                console.error('无法访问麦克风:', error);
                showNotification('无法访问麦克风，请检查权限设置', 'error');
            }
        }

        // 停止语音录制
        function stopVoiceRecording() {
            if (!appState.isRecording) return;
            
            // 停止录制
            if (appState.voiceMediaRecorder && appState.voiceMediaRecorder.state !== 'inactive') {
                appState.voiceMediaRecorder.stop();
            }
            
            appState.isRecording = false;
            
            // 更新UI
            updateRecordingUI(false);
            
            // 停止录音计时
            stopRecordingTimer();
        }

        // 更新录音UI状态
        function updateRecordingUI(isRecording) {
            const voiceRecordBtn = document.getElementById('voiceRecordBtn');
            const recordingIndicator = document.getElementById('recordingIndicator');
            
            if (isRecording) {
                voiceRecordBtn.classList.add('recording');
                voiceRecordBtn.classList.remove('pulse');
                recordingIndicator.classList.add('show');
            } else {
                voiceRecordBtn.classList.remove('recording');
                voiceRecordBtn.classList.add('pulse');
                recordingIndicator.classList.remove('show');
            }
        }

        // 开始录音计时
        function startRecordingTimer() {
            let seconds = 0;
            appState.recordingTimer = setInterval(() => {
                seconds++;
                // 更新录音指示器中的时间
                const indicator = document.getElementById('recordingIndicator');
                if (indicator) {
                    const timeDiv = indicator.querySelector('div:first-child');
                    if (timeDiv) {
                        timeDiv.textContent = `正在录音... ${seconds}秒`;
                    }
                }
            }, 1000);
        }

        // 停止录音计时
        function stopRecordingTimer() {
            if (appState.recordingTimer) {
                clearInterval(appState.recordingTimer);
                appState.recordingTimer = null;
            }
        }

        // 发送语音消息
        function sendVoiceMessage(audioUrl, duration) {
            if (!appState.isConnected) {
                showNotification('请先建立连接', 'warning');
                return;
            }
            
            if (!appState.isServerConnected) {
                showNotification('服务器连接已断开，无法发送语音', 'warning');
                return;
            }
            
            // 获取复选框状态
            const isFlash = document.getElementById('flashCheckbox').checked;
            const shouldDestroy = document.getElementById('destroyCheckbox').checked;
            
            // 语音消息不能使用闪照功能
            if (isFlash) {
                showNotification('闪照功能只支持图片和视频', 'warning');
                return;
            }
            
            // 将音频URL转换为base64
            fetch(audioUrl)
                .then(response => response.blob())
                .then(blob => {
                    const reader = new FileReader();
                    reader.onloadend = function() {
                        const base64AudioMessage = reader.result;
                        
                        // 创建消息对象
                        const now = new Date();
                        const message = {
                            id: Date.now(),
                            text: '🎤 语音消息',
                            sender: appState.currentUser.id,
                            timestamp: now,
                            type: 'voice',
                            content: base64AudioMessage,
                            duration: duration,
                            isFlash: false, // 语音消息不支持闪照
                            destroyTime: shouldDestroy ? now.getTime() + 13000 : null
                        };
                        
                        // 发送消息到服务器
                        const success = sendServerMessage({
                            type: 'chat_message',
                            data: {
                                senderId: appState.currentUser.id,
                                targetUserId: appState.connectedUser.id,
                                text: '🎤 语音消息',
                                timestamp: now.toISOString(),
                                type: 'voice',
                                content: base64AudioMessage,
                                duration: duration,
                                isFlash: false,
                                destroyTime: shouldDestroy ? new Date(now.getTime() + 13000).toISOString() : null
                            }
                        });
                        
                        if (!success) {
                            showNotification('发送语音失败，请检查网络连接', 'error');
                            return;
                        }
                        
                        // 添加到历史记录
                        appState.messageHistory.push(message);
                        
                        // 更新用户列表中的最后消息
                        updateUserLastMessage('🎤 语音消息');
                        
                        // 显示消息
                        displayVoiceMessage(message, 'sent');
                        
                        // 显示提示
                        if (shouldDestroy) {
                            showNotification('语音将在13秒后自动销毁', 'info');
                        } else {
                            showNotification('语音消息发送成功', 'success');
                        }
                    };
                    reader.readAsDataURL(blob);
                })
                .catch(error => {
                    console.error('处理语音消息失败:', error);
                    showNotification('发送语音失败', 'error');
                });
        }

        // 显示语音消息
        function displayVoiceMessage(message, direction) {
            const container = document.getElementById('messagesContainer');
            
            // 移除空状态
            const emptyState = container.querySelector('.empty-state');
            if (emptyState) {
                emptyState.remove();
            }
            
            // 创建消息元素
            const messageElement = document.createElement('div');
            messageElement.className = `message ${direction}`;
            messageElement.dataset.messageId = message.id;
            
            // 如果有倒计时，添加到消息最前面
            if (message.destroyTime) {
                // 创建倒计时容器
                const countdownContainer = document.createElement('div');
                countdownContainer.className = 'countdown-container';
                
                const countdownRing = document.createElement('div');
                countdownRing.className = 'countdown-ring';
                countdownRing.innerHTML = `
                    <svg>
                        <circle class="background" cx="10" cy="10" r="8"></circle>
                        <circle class="progress" cx="10" cy="10" r="8" 
                                stroke-dasharray="${2 * Math.PI * 8}" 
                                stroke-dashoffset="0"></circle>
                    </svg>
                `;
                
                const timerElement = document.createElement('div');
                timerElement.className = 'message-timer';
                timerElement.textContent = '13s';
                
                // 将计时器文字放到圆环内部
                countdownRing.appendChild(timerElement);
                countdownContainer.appendChild(countdownRing);
                
                // 将倒计时添加到消息元素中
                messageElement.appendChild(countdownContainer);
                
                // 启动倒计时
                startMessageCountdown(message.id, message.destroyTime, timerElement, countdownRing.querySelector('.progress'));
            }
            
            const contentElement = document.createElement('div');
            contentElement.className = 'message-content';
            
            // 只有图片和视频类型的闪照消息才显示闪照标识
            if (message.isFlash && (message.type === 'image' || message.type === 'video')) {
                const flashBadge = document.createElement('div');
                flashBadge.className = 'flash-badge';
                flashBadge.textContent = '闪照';
                contentElement.appendChild(flashBadge);
            }
            
            // 根据消息方向设置不同的样式
            const isSent = direction === 'sent';
            const primaryColor = isSent ? '#28a745' : '#007bff';
            const secondaryColor = isSent ? '#20c997' : '#0056b3';
            
            // 创建语音播放器
            const voicePlayerContainer = document.createElement('div');
            voicePlayerContainer.className = 'voice-player-container';
            voicePlayerContainer.style.cssText = `display: flex; align-items: center; gap: 12px; background: linear-gradient(135deg, ${isSent ? 'rgba(255,255,255,0.15)' : 'rgba(0,0,0,0.05)'}, ${isSent ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.02)'}); padding: 12px 16px; border-radius: 12px; margin-top: 10px; border: 1px solid ${isSent ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)'}; backdrop-filter: blur(5px); box-shadow: 0 2px 8px ${isSent ? 'rgba(40, 167, 69, 0.2)' : 'rgba(0, 123, 255, 0.1)'};`;
            
            // 播放/暂停按钮
            const playButton = document.createElement('button');
            playButton.innerHTML = '▶️';
            playButton.style.cssText = `background: linear-gradient(45deg, ${primaryColor}, ${secondaryColor}); border: none; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 16px; color: white; box-shadow: 0 3px 8px ${isSent ? 'rgba(40, 167, 69, 0.3)' : 'rgba(0, 123, 255, 0.3)'}; transition: all 0.3s ease;`;
            
            // 语音波形可视化
            const waveformContainer = document.createElement('div');
            waveformContainer.style.cssText = 'display: flex; align-items: center; gap: 3px; flex: 1; height: 24px;';
            
            // 创建多个波形条
            for (let i = 0; i < 8; i++) {
                const bar = document.createElement('div');
                const height = 8 + Math.random() * 16; // 随机高度
                bar.style.cssText = `width: 3px; height: ${height}px; background: linear-gradient(to top, ${primaryColor}, ${secondaryColor}); border-radius: 2px; opacity: 0.8; transition: all 0.3s ease;`;
                waveformContainer.appendChild(bar);
            }
            
            // 语音时长显示
            const durationDisplay = document.createElement('span');
            const minutes = Math.floor(message.duration / 60);
            const seconds = message.duration % 60;
            durationDisplay.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
            durationDisplay.style.cssText = `font-size: 13px; color: ${isSent ? 'rgba(255,255,255,0.9)' : 'var(--text-primary)'}; font-weight: 500; min-width: 45px; text-shadow: 0 1px 2px rgba(0,0,0,0.2);`;
            
            // 语音图标
            const voiceIcon = document.createElement('span');
            voiceIcon.textContent = '🎤';
            voiceIcon.style.cssText = 'font-size: 18px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));';
            
            voicePlayerContainer.appendChild(playButton);
            voicePlayerContainer.appendChild(waveformContainer);
            voicePlayerContainer.appendChild(voiceIcon);
            voicePlayerContainer.appendChild(durationDisplay);
            
            // 添加播放按钮悬停效果
            playButton.addEventListener('mouseenter', () => {
                playButton.style.transform = 'scale(1.1)';
                playButton.style.boxShadow = `0 4px 12px ${isSent ? 'rgba(40, 167, 69, 0.4)' : 'rgba(0, 123, 255, 0.4)'}`;
            });
            
            playButton.addEventListener('mouseleave', () => {
                playButton.style.transform = 'scale(1)';
                playButton.style.boxShadow = `0 3px 8px ${isSent ? 'rgba(40, 167, 69, 0.3)' : 'rgba(0, 123, 255, 0.3)'}`;
            });
            
            // 添加波形动画样式
            if (!document.getElementById('waveform-animation')) {
                const style = document.createElement('style');
                style.id = 'waveform-animation';
                style.textContent = `
                    @keyframes waveform {
                        0%, 100% { height: 8px; opacity: 0.5; }
                        50% { height: 20px; opacity: 1; }
                    }
                `;
                document.head.appendChild(style);
            }
            
            // 存储当前播放的音频元素
            let currentAudio = null;
            
            // 添加播放事件
            playButton.addEventListener('click', () => {
                if (playButton.innerHTML === '▶️') {
                    // 如果有其他音频在播放，先停止它
                    if (currentAudio) {
                        currentAudio.pause();
                        currentAudio = null;
                        
                        // 重置所有播放按钮状态
                        document.querySelectorAll('.voice-player-container button').forEach(btn => {
                            if (btn.innerHTML === '⏸️') {
                                btn.innerHTML = '▶️';
                                // 停止所有波形动画
                                const container = btn.closest('.voice-player-container');
                                if (container) {
                                    const bars = container.querySelectorAll('.voice-player-container div > div');
                                    bars.forEach(bar => {
                                        bar.style.animation = '';
                                    });
                                }
                            }
                        });
                    }
                    
                    playButton.innerHTML = '⏸️';
                    // 播放时波形条动画
                    const bars = waveformContainer.querySelectorAll('div');
                    bars.forEach((bar, index) => {
                        bar.style.animation = `waveform 1s ease-in-out ${index * 0.1}s infinite`;
                    });
                    
                    // 播放语音
                    currentAudio = new Audio(message.content);
                    currentAudio.addEventListener('ended', () => {
                        playButton.innerHTML = '▶️';
                        // 停止波形条动画
                        const bars = waveformContainer.querySelectorAll('div');
                        bars.forEach(bar => {
                            bar.style.animation = '';
                        });
                        currentAudio = null;
                    });
                    
                    currentAudio.play().catch(error => {
                        console.error('播放语音失败:', error);
                        playButton.innerHTML = '▶️';
                        // 停止波形条动画
                        const bars = waveformContainer.querySelectorAll('div');
                        bars.forEach(bar => {
                            bar.style.animation = '';
                        });
                        currentAudio = null;
                        showNotification('播放语音失败', 'error');
                    });
                } else {
                    playButton.innerHTML = '▶️';
                    // 停止播放
                    if (currentAudio) {
                        currentAudio.pause();
                        currentAudio = null;
                    }
                    // 停止波形条动画
                    const bars = waveformContainer.querySelectorAll('div');
                    bars.forEach(bar => {
                        bar.style.animation = '';
                    });
                }
            });
            
            const textElement = document.createElement('div');
            textElement.className = 'message-text';
            textElement.textContent = message.text;
            
            const timeElement = document.createElement('div');
            timeElement.className = 'message-time';
            timeElement.textContent = formatTime(message.timestamp);
            
            contentElement.appendChild(textElement);
            contentElement.appendChild(voicePlayerContainer);
            contentElement.appendChild(timeElement);
            messageElement.appendChild(contentElement);
            
            // 添加长按事件
            addLongPressEvent(messageElement, message);
            
            container.appendChild(messageElement);
            
            // 滚动到底部
            setTimeout(() => {
                container.scrollTop = container.scrollHeight;
            }, 100);
        }

        // 撤销输入操作
        function undoInput() {
            if (undoStack.length === 0) {
                showNotification('没有可撤销的操作', 'error');
                return;
            }
            
            // 将当前内容添加到重做栈
            redoStack.push(currentInputContent);
            
            // 从撤销栈中取出上一个内容
            currentInputContent = undoStack.pop();
            
            // 更新输入框内容
            const messageInput = document.getElementById('messageInput');
            messageInput.value = currentInputContent;
            
            // 更新按钮状态
            updateUndoRedoButtonStates();
            
            // 调整输入框高度
            autoResizeTextarea();
            
            showNotification('已撤销', 'success');
        }
        
        // 反撤销输入操作
        function redoInput() {
            if (redoStack.length === 0) {
                showNotification('没有可重做的操作', 'error');
                return;
            }
            
            // 将当前内容添加到撤销栈
            undoStack.push(currentInputContent);
            
            // 从重做栈中取出下一个内容
            currentInputContent = redoStack.pop();
            
            // 更新输入框内容
            const messageInput = document.getElementById('messageInput');
            messageInput.value = currentInputContent;
            
            // 更新按钮状态
            updateUndoRedoButtonStates();
            
            // 调整输入框高度
            autoResizeTextarea();
            
            showNotification('已重做', 'success');
        }
        
        // 保存当前输入内容到撤销栈
        function saveInputState() {
            const messageInput = document.getElementById('messageInput');
            const currentText = messageInput.value;
            
            // 如果内容没有变化，不保存
            if (currentText === currentInputContent) {
                return;
            }
            
            // 保存当前内容到撤销栈
            undoStack.push(currentInputContent);
            currentInputContent = currentText;
            
            // 清空重做栈
            redoStack = [];
            
            // 更新按钮状态
            updateUndoRedoButtonStates();
        }
        
        // 更新撤销反撤销按钮状态
        function updateUndoRedoButtonStates() {
            const undoBtn = document.getElementById('undo-btn');
            const redoBtn = document.getElementById('redo-btn');
            
            if (undoBtn && redoBtn) {
                undoBtn.disabled = undoStack.length === 0;
                redoBtn.disabled = redoStack.length === 0;
            }
        }

        // 播放语音消息
        function playVoiceMessage(audioUrl, playButton) {
            const audio = new Audio(audioUrl);
            
            audio.addEventListener('ended', () => {
                playButton.innerHTML = '▶️';
            });
            
            audio.play().catch(error => {
                console.error('播放语音失败:', error);
                playButton.innerHTML = '▶️';
                showNotification('播放语音失败', 'error');
            });
        }

        // 文件拖拽和分块传输功能
        const CHUNK_SIZE = 13 * 1024 * 1024; // 13MB
        const fileTransferMap = new Map(); // 存储文件传输状态
        let currentTransferId = null; // 当前传输ID
        let currentTransferType = null; // 当前传输类型
        let isTransferCancelled = false; // 传输取消标志

        
        // 初始化文件拖拽
        function initFileDropZone() {
            const dropZone = document.getElementById('fileDropZone');
            
            // 防止默认拖拽行为
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, preventDefaults, false);
                document.body.addEventListener(eventName, preventDefaults, false);
            });
            
            // 拖拽样式
            ['dragenter', 'dragover'].forEach(eventName => {
                dropZone.addEventListener(eventName, highlight, false);
            });
            
            ['dragleave', 'drop'].forEach(eventName => {
                dropZone.addEventListener(eventName, unhighlight, false);
            });
            
            // 处理文件拖拽
            dropZone.addEventListener('drop', handleDrop, false);
        }
        
        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }
        
        function highlight(e) {
            document.getElementById('fileDropZone').classList.add('dragover');
        }
        
        function unhighlight(e) {
            document.getElementById('fileDropZone').classList.remove('dragover');
        }
        
        function handleDrop(e) {
            const dt = e.dataTransfer;
            const files = dt.files;
            handleFiles(files);
        }
        
        function handleFileSelect(e) {
            const files = e.target.files;
            handleFiles(files);
        }
        
        function handleFiles(files) {
            ([...files]).forEach(uploadFile);
        }
        
        function uploadFile(file) {
            if (file.size > CHUNK_SIZE) {
                // 大文件分块传输
                uploadLargeFile(file);
            } else {
                // 小文件直接传输
                uploadSmallFile(file);
            }
        }
        
        function uploadSmallFile(file) {
            if (!appState.connectedUser) {
                showNotification('请先连接到用户', 'error');
                return;
            }
            
            const reader = new FileReader();
            
            reader.onload = function(e) {
                const fileData = {
                    type: 'chat_message',
                    data: {
                        senderId: appState.currentUser.id,
                        targetUserId: appState.connectedUser.id,
                        type: 'file',
                        fileName: file.name,
                        fileSize: file.size,
                        content: e.target.result,
                        timestamp: new Date().toISOString()
                    }
                };
                
                // 发送文件消息
                const success = sendServerMessage(fileData);
                if (success) {
                    showNotification(`文件 "${file.name}" 发送成功`, 'success');
                    
                    // 添加到本地消息历史
                    const messageObj = {
                        id: Date.now(),
                        text: '',
                        sender: appState.currentUser.id,
                        timestamp: new Date(),
                        type: 'file',
                        fileName: file.name,
                        fileSize: file.size,
                        content: e.target.result
                    };
                    appState.messageHistory.push(messageObj);
                    displayFileMessage(messageObj, 'sent');
                } else {
                    showNotification('连接已断开，无法发送文件', 'error');
                }
            };
            
            reader.readAsDataURL(file);
        }
        
        function uploadLargeFile(file) {
            if (!appState.connectedUser) {
                showNotification('请先连接到用户', 'error');
                return;
            }
            
            console.log('开始大文件分块传输:', file.name, '大小:', file.size, '分块数:', Math.ceil(file.size / CHUNK_SIZE));
            
            const fileId = generateFileId();
            const totalChunks = Math.ceil(file.size / CHUNK_SIZE);
            
            // 初始化文件传输状态
            fileTransferMap.set(fileId, {
                name: file.name,
                size: file.size,
                totalChunks: totalChunks,
                receivedChunks: new Set(),
                chunks: new Map()
            });
            
            // 显示分块传输状态
            showChunkTransferStatus(file.name, 0, totalChunks);
            
            // 分块读取和发送
            let currentChunk = 0;
            
            function readNextChunk() {
                if (currentChunk >= totalChunks) {
                    // 所有块发送完成，发送合并信号
                    sendFileMergeSignal(fileId, file.name, file.size);
                    return;
                }
                
                const start = currentChunk * CHUNK_SIZE;
                const end = Math.min(start + CHUNK_SIZE, file.size);
                const chunk = file.slice(start, end);
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    const chunkData = {
                        type: 'fileChunk',
                        data: {
                            senderId: appState.currentUser.id,
                            targetUserId: appState.connectedUser.id,
                            fileId: fileId,
                            chunkIndex: currentChunk,
                            totalChunks: totalChunks,
                            fileName: file.name,
                            fileSize: file.size,
                            data: e.target.result
                        }
                    };
                    
                    console.log('发送文件块:', currentChunk + 1, '/', totalChunks, '文件ID:', fileId);
                    const success = sendServerMessage(chunkData);
                    if (!success) {
                        showNotification('连接已断开，文件传输中断', 'error');
                        return;
                    }
                    console.log('文件块发送成功:', currentChunk + 1, '/', totalChunks);
                    
                    // 更新进度
                    updateChunkProgress(currentChunk + 1, totalChunks);
                    currentChunk++;
                    
                    // 继续下一块
                    setTimeout(readNextChunk, 100); // 延迟100ms避免阻塞
                };
                
                reader.readAsDataURL(chunk);
            }
            
            readNextChunk();
        }
        
        function generateFileId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }
        
        function showChunkTransferStatus(fileName, currentChunk, totalChunks) {
            const status = document.getElementById('chunkTransferStatus');
            const infoText = document.getElementById('chunkInfoText');
            const progressText = document.getElementById('chunkProgressText');
            
            infoText.textContent = `正在传输 "${fileName}"`;
            progressText.textContent = `${currentChunk}/${totalChunks}`;
            
            status.classList.add('show');
        }
        
        function updateChunkProgress(currentChunk, totalChunks) {
            const progressText = document.getElementById('chunkProgressText');
            const progressBar = document.getElementById('chunkProgressBar');
            
            const progress = Math.round((currentChunk / totalChunks) * 100);
            progressText.textContent = `${currentChunk}/${totalChunks} (${progress}%)`;
            progressBar.style.width = `${progress}%`;
            
            if (currentChunk === totalChunks) {
                setTimeout(() => {
                    document.getElementById('chunkTransferStatus').classList.remove('show');
                }, 2000);
            }
        }
        
        function sendFileMergeSignal(fileId, fileName, fileSize) {
            const mergeSignal = {
                type: 'fileMerge',
                data: {
                    senderId: appState.currentUser.id,
                    targetUserId: appState.connectedUser.id,
                    fileId: fileId,
                    fileName: fileName,
                    fileSize: fileSize
                }
            };
            
            const success = sendServerMessage(mergeSignal);
            if (success) {
                showNotification(`文件 "${fileName}" 传输完成`, 'success');
            }
        }
        
        // 接收文件块处理
        function handleFileChunk(chunkData) {
            console.log('接收到文件块消息:', chunkData);
            console.log('文件块数据结构:', chunkData.data);
            
            if (!chunkData.data) {
                console.error('文件块数据结构错误: 缺少data字段');
                return;
            }
            
            const { fileId, chunkIndex, totalChunks, fileName, fileSize, data } = chunkData.data;
            
            // 检查是否是新的传输
            const isNewTransfer = !currentTransferId || currentTransferId !== fileId;
            
            // 如果是新的传输，重置取消标志
            if (isNewTransfer) {
                console.log("检测到新传输，重置取消标志:", fileId);
                isTransferCancelled = false;
                currentTransferId = fileId;
                currentTransferType = "receive";
            }
            
            // 检查当前传输是否已取消
            if (isTransferCancelled && currentTransferId === fileId) {
                console.log("当前传输已取消，忽略文件块:", fileId);
                return;
            }

            
            if (!fileTransferMap.has(fileId)) {
                fileTransferMap.set(fileId, {
                    name: fileName,
                    size: fileSize,
                    totalChunks: totalChunks,
                    receivedChunks: new Set(),
                    chunks: new Map()
                });
            }
            
            const transfer = fileTransferMap.get(fileId);
            transfer.chunks.set(chunkIndex, data);
            transfer.receivedChunks.add(chunkIndex);
            
            // 显示接收进度
            showChunkTransferStatus(`接收: ${fileName}`, transfer.receivedChunks.size, totalChunks);
            updateChunkProgress(transfer.receivedChunks.size, totalChunks);
            
            // 检查是否接收完成
            if (transfer.receivedChunks.size === totalChunks) {
                mergeFileChunks(fileId);
            }
        }
        
        function mergeFileChunks(fileId) {
            console.log('开始合并文件块:', fileId);
            const transfer = fileTransferMap.get(fileId);
            if (!transfer) {
                console.warn('未找到文件传输状态:', fileId);
                return;
            }
            console.log('文件传输状态:', transfer);
            
            // 按顺序合并文件块
            let mergedData = '';
            for (let i = 0; i < transfer.totalChunks; i++) {
                const chunk = transfer.chunks.get(i);
                if (chunk) {
                    console.log(`处理块 ${i}:`, chunk.substring(0, 50) + '...');
                    
                    // 移除data:前缀和base64标识
                    let base64Data;
                    if (chunk.includes(',')) {
                        base64Data = chunk.split(',')[1];
                    } else {
                        base64Data = chunk;
                    }
                    
                    // 验证base64数据
                    if (!base64Data || base64Data.length === 0) {
                        console.error(`块 ${i} 的base64数据为空`);
                        continue;
                    }
                    
                    // 检查base64数据长度是否为4的倍数
                    const paddingLength = (4 - (base64Data.length % 4)) % 4;
                    if (paddingLength > 0) {
                        base64Data += '='.repeat(paddingLength);
                    }
                    
                    mergedData += base64Data;
                    console.log(`块 ${i} 处理完成，当前总长度:`, mergedData.length);
                } else {
                    console.error(`缺少块 ${i}`);
                }
            }
            
            // 创建下载链接
            const blob = base64ToBlob(mergedData, 'application/octet-stream');
            const url = URL.createObjectURL(blob);
            
            // 添加文件消息到聊天
            console.log('添加合并后的文件消息:', transfer.name, url);
            addFileMessage(transfer.name, transfer.size, url, true);
            
            // 清理传输状态
            fileTransferMap.delete(fileId);
            
            showNotification(`文件 "${transfer.name}" 接收完成`, 'success');
        }
        
        function base64ToBlob(base64, mimeType) {
            try {
                console.log('开始base64解码，数据长度:', base64.length);
                
                // 验证base64字符串
                if (!base64 || typeof base64 !== 'string') {
                    throw new Error('无效的base64数据');
                }
                
                const byteCharacters = atob(base64);
                const byteNumbers = new Array(byteCharacters.length);
                
                for (let i = 0; i < byteCharacters.length; i++) {
                    byteNumbers[i] = byteCharacters.charCodeAt(i);
                }
            
            const byteArray = new Uint8Array(byteNumbers);
                            const blob = new Blob([byteArray], { type: mimeType });
                            console.log('base64解码成功，blob大小:', blob.size);
                            return blob;
                        } catch (error) {
                            console.error('base64解码失败:', error);
                            console.error('base64数据预览:', base64.substring(0, 100));
                            throw error;
                        }
                    }        
        function addFileMessage(fileName, fileSize, url, isReceived = false) {
            const messagesContainer = document.getElementById('messagesContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${isReceived ? 'received' : 'sent'}`;
            messageDiv.dataset.messageId = Date.now().toString(); // 添加消息ID
            
            const fileIcon = getFileIcon(fileName);
            const formattedSize = formatFileSize(fileSize);
            
            messageDiv.innerHTML = `
                <div class="message-content">
                    <div class="file-message">
                        <span class="file-icon">${fileIcon}</span>
                        <div class="file-details">
                            <div class="file-name">${fileName}</div>
                            <div class="file-size">${formattedSize}</div>
                        </div>
                        <button class="download-btn" onclick="downloadFile('${fileName}', '${url}')">⬇</button>
                    </div>
                    <div class="message-time">${new Date().toLocaleTimeString()}</div>
                </div>
            `;
            
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
        
        function getFileIcon(fileName) {
            const ext = fileName.split('.').pop().toLowerCase();
            const iconMap = {
                'pdf': '📄',
                'doc': '📝', 'docx': '📝',
                'xls': '📊', 'xlsx': '📊',
                'ppt': '📽️', 'pptx': '📽️',
                'txt': '📃',
                'jpg': '🖼️', 'jpeg': '🖼️', 'png': '🖼️', 'gif': '🖼️',
                'mp4': '🎬', 'avi': '🎬', 'mov': '🎬',
                'mp3': '🎵', 'wav': '🎵',
                'zip': '🗜️', 'rar': '🗜️',
                'js': '📜', 'html': '🌐', 'css': '🎨'
            };
            return iconMap[ext] || '📎';
        }
        
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }
        
        function downloadFile(fileName, fileContent) {
            // 如果有文件内容，创建下载链接
            if (fileContent) {
                try {
                    // 创建下载链接
                    const link = document.createElement('a');
                    link.href = fileContent;
                    link.download = fileName;
                    
                    // 对于base64数据，需要设置正确的属性
                    if (fileContent.startsWith('data:')) {
                        link.setAttribute('target', '_blank');
                    }
                    
                    // 触发下载
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                    
                    showNotification('文件下载已开始', 'success');
                } catch (error) {
                    showNotification('下载失败', 'error');
                    console.error('下载错误:', error);
                }
            } else {
                showNotification('文件内容不存在', 'error');
            }
        }

        // 安全的视频流设置函数
        appState.setVideoStream = function(videoElement, stream) {
            console.log('📹 setVideoStream被调用');
            console.log('📹 视频元素:', videoElement);
            console.log('📹 视频流:', stream);
            
            if (!videoElement) {
                console.error('视频元素不存在');
                return;
            }
            
            if (!stream) {
                console.error('视频流不存在');
                return;
            }
            
            // 检查是否是相同的流，避免重复设置
            if (videoElement.srcObject === stream) {
                console.log('📹 相同的视频流，跳过设置');
                return;
            }
            
            try {
                // 检查流是否有视频轨道
                const videoTracks = stream.getVideoTracks();
                console.log('📹 视频轨道数量:', videoTracks.length);
                
                if (videoTracks.length === 0) {
                    console.warn('流中没有视频轨道');
                    return;
                }
                
                // 详细检查视频轨道
                videoTracks.forEach((track, index) => {
                    console.log(`📹 视频轨道 ${index}:`, {
                        id: track.id,
                        enabled: track.enabled,
                        muted: track.muted,
                        readyState: track.readyState,
                        label: track.label
                    });
                    
                    // 如果轨道被静音，尝试启用
                    if (track.muted) {
                        console.warn('📹 视频轨道被静音，尝试启用');
                        track.enabled = true;
                    }
                });
                
                // 检查视频轨道是否启用
                if (!videoTracks[0].enabled) {
                    console.warn('视频轨道未启用，尝试启用');
                    videoTracks[0].enabled = true;
                }
                
                // 设置视频源
                console.log('📹 设置srcObject');
                console.log('📹 设置前 - videoElement.srcObject:', videoElement.srcObject);
                console.log('📹 设置前 - videoElement.readyState:', videoElement.readyState);
                console.log('📹 设置前 - videoElement.paused:', videoElement.paused);
                
                videoElement.srcObject = stream;
                
                console.log('📹 设置后 - videoElement.srcObject:', videoElement.srcObject);
                
                // 监听视频元素事件
                videoElement.onloadedmetadata = () => {
                    console.log('📹 视频元数据已加载');
                    console.log('📹 视频尺寸:', videoElement.videoWidth, 'x', videoElement.videoHeight);
                    console.log('📹 视频元素ID:', videoElement.id);
                    console.log('📹 视频元素类名:', videoElement.className);
                    
                    // 如果视频尺寸为0，尝试重新加载
                    if (videoElement.videoWidth === 0 || videoElement.videoHeight === 0) {
                        console.warn('📹 视频尺寸为0，尝试重新加载');
                        videoElement.load();
                        setTimeout(() => {
                            videoElement.play().catch(e => console.error('重新播放失败:', e));
                        }, 500);
                    }
                };
                
                videoElement.onplay = () => {
                    console.log('📹 视频开始播放');
                };
                
                videoElement.onerror = (e) => {
                    console.error('📹 视频播放错误:', e);
                };
                
                // 监听视频轨道状态变化
                stream.getVideoTracks().forEach(track => {
                    track.onmute = () => {
                        console.warn('📹 视频轨道被静音');
                        // 尝试重新启用
                        setTimeout(() => {
                            track.enabled = true;
                            console.log('📹 尝试重新启用视频轨道');
                        }, 100);
                    };
                    
                    track.onunmute = () => {
                        console.log('📹 视频轨道取消静音');
                    };
                });
                
                // 确保视频播放，添加延迟避免AbortError
                setTimeout(() => {
                    console.log('📹 尝试播放视频');
                    videoElement.play().then(() => {
                        console.log('📹 视频播放成功');
                    }).catch(error => {
                        console.error('视频播放失败:', error);
                        // 不抛出错误，避免中断连接
                    });
                }, 100);
                
                console.log('视频流设置成功');
            } catch (error) {
                console.error('设置视频流时出错:', error);
            }
        };
    </script>
<!-- 侧滑设置面板 -->
    <div class="settings-overlay" id="settingsOverlay" onclick="closeSettingsPanel()"></div>
    <div class="settings-panel" id="settingsPanel">
        <div class="panel-header">
            <h2 class="panel-title">连接设置</h2>
            <p class="panel-subtitle">输入对方ID建立连接</p>
        </div>
        
        <div class="connection-form">
            <div class="form-group">
                <label class="form-label">对方用户ID</label>
                <input 
                    type="text" 
                    class="form-input" 
                    id="targetIdInput"
                    placeholder="请输入要连接的用户ID"
                    onkeypress="handleTargetKeyPress(event)"
                >
            </div>
            
            <button class="connect-btn" onclick="establishConnection()">
                建立连接
            </button>
        </div>
        
        <div class="connection-status">
            <div class="status-indicator">
                <span class="status-dot" id="statusDot"></span>
                <span id="statusText">等待连接</span>
            </div>
        </div>

        <!-- 在线用户区域 -->
        <div class="online-users-section">
            <div class="section-header">
                <h3 class="section-title">在线用户</h3>
                <span class="user-count" id="onlineUserCount">0</span>
            </div>
            <div class="users-list" id="onlineUsersList">
                <div class="empty-users">
                    <p>暂无在线用户</p>
                </div>
            </div>
        </div>

        <!-- 聊天记录区域 -->
        <div class="users-section">
            <div class="section-header">
                <h3 class="section-title">聊天记录</h3>
                <span class="user-count" id="userCount">0</span>
            </div>
            <div class="users-list" id="usersList">
                <div class="empty-users">
                    <p>暂无聊天记录</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 左滑提示 -->
    <div class="swipe-hint" id="swipeHint">左滑打开设置</div>

    <!-- 录音状态提示 -->
    <div class="recording-indicator" id="recordingIndicator">
        <div>正在录音...</div>
        <div class="recording-wave">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
        </div>
        <div>松开发送</div>
    </div>
<script src="call-monitor.js"></script>
<script src="debug-50s.js"></script>
<script src="websocket-heartbeat.js"></script>
</body>
</html>



